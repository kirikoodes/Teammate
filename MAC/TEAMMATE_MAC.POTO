def list_audio_devices():
    devices = sd.query_devices()
    ins, outs = [], []
    for idx, dev in enumerate(devices):
        if dev["max_input_channels"] > 0:
            ins.append((idx, dev["name"], dev["max_input_channels"]))
        if dev["max_output_channels"] > 0:
            outs.append((idx, dev["name"], dev["max_output_channels"]))
    return ins, outs

def print_audio_devices():
    ins, outs = list_audio_devices()
    print("\n[AUDIO INPUTS]")
    for idx, name, ch in ins:
        print(f"{idx:>3} | {name} | in_ch={ch}")
    print("\n[AUDIO OUTPUTS]")
    for idx, name, ch in outs:
        print(f"{idx:>3} | {name} | out_ch={ch}")
    print()

def list_midi_outputs():
    if mido is None:
        return []
    return list(enumerate(mido.get_output_names()))

def print_midi_outputs():
    print("\n[MIDI OUTPUTS]")
    outs = list_midi_outputs()
    if not outs:
        print("none")
    for idx, name in outs:
        print(f"{idx:>3} | {name}")
    print()

def list_midi_inputs():
    if mido is None:
        return []
    return list(enumerate(mido.get_input_names()))

def print_midi_inputs():
    print("\n[MIDI INPUTS]")
    ins = list_midi_inputs()
    if not ins:
        print("none")
    for idx, name in ins:
        print(f"{idx:>3} | {name}")
    print()

def apply_profile(params_ref, name):
    profiles = {
        "ambient": {
            "profile_mode": "ambient",
            "density": 0.78,
            "contrast_amount": 0.15,
            "silence_bias": 0.05,
            "reply_probability": 0.92,
            "reverse_probability": 0.08,
            "slice_probability": 0.18,
            "swarm_enabled": True,
            "swarm_gain": 0.22,
            "swarm_count": 6,
            "compress_mode": "ambient",
        },
        "acoustique": {
            "profile_mode": "acoustique",
            "density": 0.55,
            "contrast_amount": 0.30,
            "silence_bias": 0.14,
            "reply_probability": 0.75,
            "reverse_probability": 0.08,
            "slice_probability": 0.25,
            "compress_mode": "off",
        },
        "rythmique": {
            "profile_mode": "rythmique",
            "density": 0.85,
            "contrast_amount": 0.70,
            "silence_bias": 0.03,
            "reply_probability": 0.96,
            "reverse_probability": 0.18,
            "slice_probability": 0.75,
            "phrase_min_events": 1,
            "phrase_max_events": 5,
            "compress_mode": "gentle",
        },
    }
    name = name.strip().lower()
    if name not in profiles:
        return False
    for k, v in profiles[name].items():
        params_ref.set(k, v)
    return True

def apply_self_sustain(params_ref, name):
    presets = {
        "off": {"self_sustain_mode": "off"},
        "low": {"self_sustain_mode": "low", "reply_probability": 0.82, "silence_bias": 0.10, "density": 0.62},
        "med": {"self_sustain_mode": "med", "reply_probability": 0.90, "silence_bias": 0.06, "density": 0.74, "swarm_enabled": True},
        "high": {"self_sustain_mode": "high", "reply_probability": 0.97, "silence_bias": 0.02, "density": 0.86, "swarm_enabled": True, "swarm_count": 8},
    }
    name = name.strip().lower()
    if name not in presets:
        return False
    for k, v in presets[name].items():
        params_ref.set(k, v)
    return True

def randomize_feel(params_ref):
    rp   = round(random.uniform(0.30, 1.00), 2)
    den  = round(random.uniform(0.15, 0.95), 2)
    sil  = round(random.uniform(0.00, 0.45), 2)
    params_ref.set("reply_probability", rp)
    params_ref.set("density", den)
    params_ref.set("silence_bias", sil)

    sw_imin    = round(random.uniform(0.02, 0.15), 3)
    sw_imax    = round(random.uniform(sw_imin + 0.05, 0.45), 3)
    sw_slice   = round(random.uniform(0.10, 0.90), 2)
    sw_rev     = round(random.uniform(0.05, 0.40), 2)
    sw_jitter  = round(random.uniform(5.0, 80.0), 1)
    sw_mode    = random.choice(["FOLLOW", "DRIFT", "SPLIT", "GHOST"])
    sw_str     = round(random.uniform(0.30, 1.00), 2)
    sw_cal     = random.random() > 0.5
    sw_live    = random.random() > 0.5
    sw_upd     = round(random.uniform(0.05, 0.50), 2)
    sw_topk    = random.randint(2, 16)
    sw_cw      = round(random.uniform(0.0, 2.0), 2)
    sw_pw      = round(random.uniform(0.0, 2.0), 2)
    sw_ew      = round(random.uniform(0.0, 2.0), 2)
    sw_inertia = round(random.uniform(0.20, 0.90), 2)
    params_ref.set("swarm_interval_min",          sw_imin)
    params_ref.set("swarm_interval_max",          sw_imax)
    params_ref.set("swarm_slice_probability",     sw_slice)
    params_ref.set("swarm_reverse_probability",   sw_rev)
    params_ref.set("swarm_jitter_ms",             sw_jitter)
    params_ref.set("swarm_follow_mode",           sw_mode)
    params_ref.set("swarm_follow_strength",       sw_str)
    params_ref.set("swarm_follow_calltrans",      sw_cal)
    params_ref.set("swarm_follow_live",           sw_live)
    params_ref.set("swarm_follow_update_sec",     sw_upd)
    params_ref.set("swarm_follow_top_k",          sw_topk)
    params_ref.set("swarm_follow_centroid_weight",sw_cw)
    params_ref.set("swarm_follow_pitch_weight",   sw_pw)
    params_ref.set("swarm_follow_energy_weight",  sw_ew)
    params_ref.set("swarm_follow_inertia",        sw_inertia)

    print(f"  random >> reply={rp}  density={den}  silence={sil}")
    print(f"           swarm mode={sw_mode}  strength={sw_str}  slice={sw_slice}  rev={sw_rev}  inertia={sw_inertia}")

def apply_xy_mapping(params_ref):
    snap = params_ref.snapshot()
    if not snap.get("xy_enabled", False):
        return
    x = max(0.0, min(1.0, float(snap.get("xy_x", 0.5))))
    y = max(0.0, min(1.0, float(snap.get("xy_y", 0.5))))
    params_ref.set("density", 0.15 + 0.80 * x)
    params_ref.set("reply_probability", 0.35 + 0.60 * x)
    params_ref.set("silence_bias", max(0.0, min(1.0, 0.40 - 0.35 * x)))
    params_ref.set("phrase_min_events", max(1, int(round(1 + 4 * x))))
    params_ref.set("phrase_max_events", max(int(params_ref.snapshot().get("phrase_min_events", 1)), int(round(3 + 9 * x))))
    params_ref.set("slice_probability", 0.05 + 0.75 * y)
    params_ref.set("contrast_amount", 0.10 + 0.80 * y)
    params_ref.set("swarm_follow_strength", 0.35 + 0.65 * y)

class XYLiveController:
    def __init__(self, params_ref):
        self.params_ref = params_ref
        self.thread = None
        self.running = False

    def start(self):
        if tk is None:
            raise RuntimeError("tkinter not available")
        if self.running:
            return
        self.running = True
        self.thread = threading.Thread(target=self._run, daemon=True)
        self.thread.start()

    def _run(self):
        root = tk.Tk()
        root.title("TEAMMATE XY")
        root.configure(bg="black")
        size = 320
        canvas = tk.Canvas(root, width=size, height=size, bg="black", highlightthickness=1, highlightbackground="#00ff88")
        canvas.pack()
        info = tk.Label(root, text="X=CONTINUITY  Y=TRANSFORM (NO REVERSE)", bg="black", fg="#00ff88")
        info.pack()
        self.params_ref.set("xy_enabled", True)

        def update_xy(event):
            if self.params_ref.snapshot().get("xy_mode", "hold") != "live":
                return
            x = max(0.0, min(1.0, event.x / float(size)))
            y = 1.0 - max(0.0, min(1.0, event.y / float(size)))
            self.params_ref.set("xy_x", x)
            self.params_ref.set("xy_y", y)
            apply_xy_mapping(self.params_ref)

        def redraw():
            canvas.delete("dot")
            snap = self.params_ref.snapshot()
            x = int(max(0.0, min(1.0, snap.get("xy_x", 0.5))) * size)
            y = int((1.0 - max(0.0, min(1.0, snap.get("xy_y", 0.5)))) * size)
            canvas.create_oval(x-5, y-5, x+5, y+5, fill="#00ff88", outline="", tags="dot")
            if self.running:
                root.after(50, redraw)
            else:
                try:
                    root.destroy()
                except Exception:
                    pass

        canvas.bind("<Motion>", update_xy)
        canvas.bind("<B1-Motion>", update_xy)
        canvas.bind("<Button-1>", update_xy)
        root.protocol("WM_DELETE_WINDOW", lambda: (self.params_ref.set("xy_enabled", False), setattr(self, "running", False)))
        redraw()
        root.mainloop()

    def stop(self):
        self.running = False
        self.params_ref.set("xy_enabled", False)

class VisualEngine:
    STRATEGY_SYMBOLS = {
        "IMITATION":     ("≈≈≈", "#00ffcc"),
        "CONTRASTE":     ("↔↔↔", "#ff6600"),
        "DENSIFICATION": ("▲▲▲", "#ff00ff"),
        "SPARSE":        ("···", "#ffff00"),
        "SILENCE":       ("───", "#4488ff"),
        "NONE":          ("   ", "#222222"),
    }

    def __init__(self, vis_state, grain_cloud):
        self.vis_state = vis_state
        self.grain_cloud = grain_cloud
        self._thread = None
        self.running = False
        self._root = None
        self._start_time = 0.0

    def start(self):
        if tk is None:
            raise RuntimeError("tkinter not available")
        if self.running:
            return
        self.running = True
        self._start_time = time.time()
        self._thread = threading.Thread(target=self._run, daemon=True)
        self._thread.start()

    def stop(self):
        self.running = False
        if self._root:
            try:
                self._root.after(0, self._root.destroy)
            except Exception:
                pass

    def _amp_bar(self, val, width=12):
        filled = int(min(1.0, max(0.0, val)) * width)
        return "█" * filled + "░" * (width - filled)

    def _elapsed(self):
        t = time.time() - self._start_time
        m = int(t // 60)
        s = t % 60
        return f"{m:02d}:{s:05.2f}"

    def _run(self):  # noqa: C901
        import math as _math
        root = tk.Tk()
        self._root = root
        root.title("TEAMMATE.POTO")
        root.configure(bg="#000000")
        root.geometry("1600x950")
        root.resizable(False, False)
        root.protocol("WM_DELETE_WINDOW", self.stop)

        # ── Terminal-style display — ONE character grid, old+new phosphor ──
        # Every data point IS a character. No separate panels.
        canvas = tk.Canvas(root, bg="#000000", highlightthickness=0)
        canvas.pack(fill="both", expand=True)

        # Character grid — big monospace font, each char is the visual unit
        FONT = ("Courier New", 18, "bold")
        CW, CH = 12, 24      # px per char (approx at 18pt bold Courier on Win)
        COLS   = 128         # 128 × 12 = 1536px
        ROWS   = 38          # 38  × 24 = 912px

        # Phosphor color palette
        C_DEAD   = "#030803"   # dead cell — near black with green tint
        C_BORDER = "#1a3a1a"   # box-drawing chars
        C_HDR    = "#00cc44"   # header text — phosphor green
        C_DIM    = "#004422"   # dim text
        C_DATA   = "#00ff88"   # live values — brighter green
        C_STATE  = "#aaffaa"   # machine state

        STRAT_COL = {
            "DENSIFICATION": "#cc00bb",
            "IMITATION":     "#00aacc",
            "CONTRASTE":     "#cc6600",
            "SPARSE":        "#999900",
            "SILENCE":       "#2244bb",
            "NONE":          "#020602",
        }
        # Layout
        HDR_ROWS  = 3    # top border + data + state separator
        DEC_ROWS  = 14   # decision / intelligence panel
        SEP_ROW   = HDR_ROWS + DEC_ROWS          # separator before log
        LOG_ROWS  = ROWS - SEP_ROW - 2           # scrolling log rows
        INNER_W   = COLS - 2

        # Pre-create one canvas text item per cell, positioned left-to-right
        cell_items = {}
        for r in range(ROWS):
            for c in range(COLS):
                iid = canvas.create_text(
                    c * CW + 2, r * CH + 2,
                    text=" ", fill=C_DEAD,
                    font=FONT, anchor="nw"
                )
                cell_items[(r, c)] = iid

        # Previous frame buffer for delta-updates (only redraw changed cells)
        prev_buf = [[(" ", C_DEAD)] * COLS for _ in range(ROWS)]
        prev  = {"strategy": "__init__", "state": "__init__",
                 "since": time.time(), "grain_count": 0}
        log_buf = []   # list of (str, hex_color)

        def _rms_bar(v, w=20):
            filled = max(0, min(w, int(v * w * 18)))
            return "█" * filled + "░" * (w - filled)

        def _wbar(v, w=8):
            filled = max(0, min(w, int(v * w)))
            return "█" * filled + "░" * (w - filled)

        def _fade_col(hx, f):
            rv = int(int(hx[1:3], 16) * f)
            gv = int(int(hx[3:5], 16) * f)
            bv = int(int(hx[5:7], 16) * f)
            return f"#{rv:02x}{gv:02x}{bv:02x}"

        def _put(buf, r, c, ch, col):
            if 0 <= r < ROWS and 0 <= c < COLS:
                buf[r][c] = (ch, col)

        def _write(buf, r, c, text, col):
            for i, ch in enumerate(text):
                _put(buf, r, c + i, ch, col)

        def _hsep(buf, r, label="", lc=C_DIM):
            _put(buf, r, 0, "├", C_BORDER)
            _write(buf, r, 1, "─" * INNER_W, C_BORDER)
            _put(buf, r, COLS-1, "┤", C_BORDER)
            if label:
                _write(buf, r, 3, f" {label} ", lc)

        def build_frame(vs, snap):
            buf = [[(" ", C_DEAD)] * COLS for _ in range(ROWS)]

            strategy  = vs.get("strategy", "NONE")
            tm_state  = vs.get("machine_state", "LISTENING")
            rms_in    = vs.get("avg_rms", 0.0)
            rms_out   = vs.get("avg_rms_out", 0.0)
            freq      = vs.get("avg_freq", 0.0)
            corpus    = vs.get("corpus", 0)
            n_grains  = vs.get("poto_grains", 0)
            onset     = vs.get("onset", False)
            ghost     = snap.get("ghost_mode", False)
            poto_on   = snap.get("poto_enabled", False)
            swarm     = vs.get("swarm_enabled", False)
            poto_mode = snap.get("poto_input_mode", "mic")
            calltrans = snap.get("calltrans_enabled", False)
            weights   = vs.get("last_weights", {})
            factors   = vs.get("last_factors", {})
            grains_s  = vs.get("grains_snap", [])
            s_col     = STRAT_COL.get(strategy, C_DEAD)
            sym, _    = self.STRATEGY_SYMBOLS.get(strategy, ("   ", "#222222"))
            elapsed   = self._elapsed()

            # ── Row 0: top border ──────────────────────────────────────────
            _put(buf, 0, 0, "┌", C_BORDER)
            _write(buf, 0, 1, "─" * INNER_W, C_BORDER)
            _put(buf, 0, COLS-1, "┐", C_BORDER)
            _write(buf, 0, 2, " TEAMMATE.POTO ", C_HDR)
            _write(buf, 0, COLS - 2 - len(elapsed), elapsed, C_DATA)

            # ── Row 1: live status ─────────────────────────────────────────
            _put(buf, 1, 0, "│", C_BORDER)
            _put(buf, 1, COLS-1, "│", C_BORDER)
            modes = []
            if ghost:    modes.append("GHOST")
            if poto_on:  modes.append(f"POtO/{poto_mode}")
            if swarm:    modes.append("SWARM")
            if calltrans:modes.append("CALLTRANS")
            if onset:    modes.append("ONSET!")
            stlb = f" {sym} {strategy:<13}"
            bars = f"  in:{_rms_bar(rms_in,14)}  out:{_rms_bar(rms_out,14)}"
            info = f"  {freq:>5.0f}Hz  c:{corpus:<4} g:{n_grains:<3}"
            mstr = ("  " + " ".join(modes)) if modes else ""
            _write(buf, 1, 1, stlb, s_col)
            _write(buf, 1, 1+len(stlb), bars, C_HDR)
            _write(buf, 1, 1+len(stlb)+len(bars), info, C_DATA)
            _write(buf, 1, 1+len(stlb)+len(bars)+len(info), mstr, "#00ffaa" if onset else C_DIM)

            # ── Row 2: separator + machine state ──────────────────────────
            state_col = {"LISTENING":"#00cc44","THINKING":"#cc8800","RESTING":"#224488"}.get(tm_state, C_DIM)
            _hsep(buf, 2, tm_state, state_col)

            # ══ DECISION PANEL (rows 3..HDR_ROWS+DEC_ROWS-1) ═════════════
            r = HDR_ROWS

            # ── Weights bar chart ──────────────────────────────────────────
            _write(buf, r, 2, " WEIGHTS", C_DIM); r += 1
            strat_order = ["IMITATION","CONTRASTE","DENSIFICATION","SPARSE","SILENCE"]
            row_a, row_b = r, r+1
            col_cur = 2
            for si, sn in enumerate(strat_order):
                w = weights.get(sn, 0.0)
                sc2 = STRAT_COL.get(sn, C_DIM)
                bar = _wbar(w, 10)
                lbl = f" {sn[:5]}:{w:.2f} {bar} "
                target_row = row_a if si < 3 else row_b
                if col_cur + len(lbl) < COLS - 2:
                    _write(buf, target_row, col_cur if si < 3 else 2 + (si-3)*32, lbl,
                           sc2 if w == max(weights.values(), default=0) else C_DIM)
            _put(buf, row_a, 0, "│", C_BORDER); _put(buf, row_a, COLS-1, "│", C_BORDER)
            _put(buf, row_b, 0, "│", C_BORDER); _put(buf, row_b, COLS-1, "│", C_BORDER)
            r = row_b + 1

            # ── Factors ────────────────────────────────────────────────────
            _put(buf, r, 0, "│", C_BORDER); _put(buf, r, COLS-1, "│", C_BORDER)
            _write(buf, r, 2, " FACTORS", C_DIM)
            fstr = (f"  energy={factors.get('energy',0):.3f}"
                    f"  brightness={factors.get('brightness',0):.3f}"
                    f"  intent.end={factors.get('intent.end',0):.3f}"
                    f"  intent.cont={factors.get('intent.cont',0):.3f}"
                    f"  density={factors.get('density',0):.2f}"
                    f"  sil_bias={factors.get('silence_bias',0):.2f}")
            _write(buf, r, 10, fstr[:COLS-12], C_HDR); r += 1

            # ── Reasons ────────────────────────────────────────────────────
            _put(buf, r, 0, "│", C_BORDER); _put(buf, r, COLS-1, "│", C_BORDER)
            reasons = factors.get("reasons", [])
            if reasons:
                rstr = "  →  " + "   ".join(reasons)
                _write(buf, r, 2, " MODIFIERS", C_DIM)
                _write(buf, r, 13, rstr[:COLS-15], "#cc8800")
            else:
                _write(buf, r, 2, " MODIFIERS  none", C_DIM)
            r += 1

            # ── Params ─────────────────────────────────────────────────────
            _put(buf, r, 0, "│", C_BORDER); _put(buf, r, COLS-1, "│", C_BORDER)
            pstr = (f"  reply_prob={snap.get('reply_probability',0):.2f}"
                    f"  contrast={snap.get('contrast_amount',0):.2f}"
                    f"  phrase={snap.get('phrase_min_events',1)}-{snap.get('phrase_max_events',4)}ev"
                    f"  calltrans={'ON' if calltrans else 'OFF'}"
                    f"  ghost={'ON' if ghost else 'OFF'}"
                    f"  poto={'ON' if poto_on else 'OFF'}")
            _write(buf, r, 2, " PARAMS", C_DIM)
            _write(buf, r, 9, pstr[:COLS-11], C_DATA); r += 1

            # ── Corpus grains snapshot ─────────────────────────────────────
            _put(buf, r, 0, "│", C_BORDER); _put(buf, r, COLS-1, "│", C_BORDER)
            _write(buf, r, 2, " GRAINS", C_DIM)
            if grains_s:
                gpos = 10
                for g in grains_s[:12]:
                    fv = g.get("freq", 0.0)
                    av = g.get("amp", 0.0)
                    ch = "●" if av > 0.5 else ("◉" if av > 0.2 else "○")
                    gtxt = f" {ch}{fv:>5.0f}Hz "
                    if gpos + len(gtxt) < COLS - 2:
                        _write(buf, r, gpos, gtxt, s_col if poto_on else "#00bb44")
                        gpos += len(gtxt)
            else:
                _write(buf, r, 10, "  —", C_DIM)
            r += 1

            # fill remaining decision rows with border only
            while r < SEP_ROW:
                _put(buf, r, 0, "│", C_BORDER)
                _put(buf, r, COLS-1, "│", C_BORDER)
                r += 1

            # ── Separator before log ───────────────────────────────────────
            _hsep(buf, SEP_ROW, "HISTORY", C_DIM)

            # ── Scrolling log ──────────────────────────────────────────────
            visible = log_buf[-LOG_ROWS:]
            for i, (ltxt, lcol) in enumerate(visible):
                fade = 0.25 + 0.75 * (i / max(1, len(visible) - 1))
                rl = SEP_ROW + 1 + i
                _put(buf, rl, 0, "│", C_BORDER)
                _put(buf, rl, COLS-1, "│", C_BORDER)
                _write(buf, rl, 1, ltxt[:INNER_W], _fade_col(lcol, fade))

            # ── Bottom border ──────────────────────────────────────────────
            _put(buf, ROWS-1, 0, "└", C_BORDER)
            _write(buf, ROWS-1, 1, "─" * INNER_W, C_BORDER)
            _put(buf, ROWS-1, COLS-1, "┘", C_BORDER)

            return buf

        def update():
            if not self.running:
                try: root.destroy()
                except Exception: pass
                return
            try:
                vs        = dict(self.vis_state)
                snap      = vs.get("params_snap", {})
                strategy  = vs.get("strategy", "NONE")
                tm_state  = vs.get("machine_state", "LISTENING")
                rms       = vs.get("avg_rms", 0.0)
                n_grains  = vs.get("poto_grains", 0)
                s_col     = STRAT_COL.get(strategy, C_DEAD)
                grains_s  = vs.get("grains_snap", [])

                # Partition log — new entry on state/strategy change
                if strategy != prev["strategy"] or tm_state != prev["state"]:
                    dur = time.time() - prev["since"]
                    ts  = self._elapsed()
                    sym, _ = self.STRATEGY_SYMBOLS.get(strategy, ("   ", "#222222"))
                    if strategy == "SILENCE":
                        line = f" {ts}  ───  SIL  {dur:.1f}s"
                        lcol = "#2244bb"
                    elif strategy == "NONE":
                        line = f" {ts}  {tm_state}"
                        lcol = "#003311"
                    else:
                        line = f" {ts}  {sym} {strategy:<12}  {dur:.1f}s"
                        lcol = s_col
                    log_buf.append((line, lcol))
                    if len(log_buf) > 80:
                        log_buf.pop(0)
                    prev["strategy"] = strategy
                    prev["state"]    = tm_state
                    prev["since"]    = time.time()

                prev["grain_count"] = n_grains

                # Build new frame and apply only changed cells (delta render)
                buf = build_frame(vs, snap)
                for r in range(ROWS):
                    for c in range(COLS):
                        nc = buf[r][c]
                        if nc != prev_buf[r][c]:
                            canvas.itemconfig(cell_items[(r, c)],
                                text=nc[0], fill=nc[1])
                            prev_buf[r][c] = nc

            except Exception:
                pass
            root.after(80, update)

        root.after(300, update)
        root.mainloop()
        self.running = False




def apply_preset(params_ref, name):
    presets = {
        "soft": {"calltrans_enabled": True, "calltrans_amount": 0.25, "calltrans_follow_input_only": False, "calltrans_timbre_weight": 1.0, "calltrans_pitch_weight": 0.25, "calltrans_duration_weight": 0.15, "calltrans_energy_weight": 0.35},
        "hard": {"calltrans_enabled": True, "calltrans_amount": 0.85, "calltrans_follow_input_only": False, "calltrans_timbre_weight": 1.0, "calltrans_pitch_weight": 0.50, "calltrans_duration_weight": 0.35, "calltrans_energy_weight": 0.60},
        "timbre_only": {"calltrans_enabled": True, "calltrans_amount": 1.0, "calltrans_follow_input_only": True, "calltrans_timbre_weight": 1.0, "calltrans_pitch_weight": 0.0, "calltrans_duration_weight": 0.0, "calltrans_energy_weight": 0.20},
        "hybrid": {"calltrans_enabled": True, "calltrans_amount": 0.50, "calltrans_follow_input_only": False, "calltrans_timbre_weight": 1.0, "calltrans_pitch_weight": 0.35, "calltrans_duration_weight": 0.25, "calltrans_energy_weight": 0.45},
    }
    name = name.strip().lower()
    if name not in presets:
        return False
    for k, v in presets[name].items():
        params_ref.set(k, v)
    return True

class ParamsRef:
    def __init__(self):
        self.params = dict(DEFAULT_PARAMS)
        self.lock = threading.Lock()
    def snapshot(self):
        with self.lock:
            return dict(self.params)
    def set(self, key, value):
        with self.lock:
            meta = PARAM_META.get(key, {})
            if meta.get("type") in {"int", "float"}:
                value = clamp_value(key, value)
            elif meta.get("type") == "str":
                value = str(value).strip()
            elif meta.get("type") == "bool":
                value = bool(value)
            self.params[key] = value
            if self.params["phrase_min_events"] > self.params["phrase_max_events"]:
                self.params["phrase_max_events"] = self.params["phrase_min_events"]
            if self.params["min_reply_delay"] > self.params["max_reply_delay"]:
                self.params["max_reply_delay"] = self.params["min_reply_delay"]
            if self.params["swarm_interval_min"] > self.params["swarm_interval_max"]:
                self.params["swarm_interval_max"] = self.params["swarm_interval_min"]
            if self.params["midi_note_in_min"] > self.params["midi_note_in_max"]:
                self.params["midi_note_in_max"] = self.params["midi_note_in_min"]
            if self.params["midi_note_out_min"] > self.params["midi_note_out_max"]:
                self.params["midi_note_out_max"] = self.params["midi_note_out_min"]
            if self.params["corpus_window_start"] > self.params["corpus_window_end"]:
                self.params["corpus_window_end"] = self.params["corpus_window_start"]

    def save_to_file(self, path):
        import json
        with self.lock:
            data = dict(self.params)
        with open(path, "w", encoding="utf-8") as f:
            json.dump(data, f, indent=2)

    def load_from_file(self, path):
        import json
        with open(path, "r", encoding="utf-8") as f:
            data = json.load(f)
        # apply each key through set() for validation
        for k, v in data.items():
            if k in DEFAULT_PARAMS:
                try:
                    self.set(k, v)
                except Exception:
                    pass

class MidiManager:
    def __init__(self, params_ref=None):
        self.params_ref = params_ref
        self.port = None
        self.port_name = None
        self.input_port = None
        self.input_port_name = None
        self.last_input_note = None
        self.last_input_velocity = 0
        self.last_input_time = 0.0
        self.lock = threading.Lock()
    def open_index(self, idx):
        if mido is None:
            raise RuntimeError("mido not installed")
        names = mido.get_output_names()
        if idx < 0 or idx >= len(names):
            raise IndexError("invalid midi output index")
        self.close()
        self.port_name = names[idx]
        self.port = mido.open_output(self.port_name)
        return self.port_name
    def open_input_index(self, idx):
        if mido is None:
            raise RuntimeError("mido not installed")
        names = mido.get_input_names()
        if idx < 0 or idx >= len(names):
            raise IndexError("invalid midi input index")
        self.close_input()
        self.input_port_name = names[idx]
        self.input_port = mido.open_input(self.input_port_name, callback=self._input_callback)
        return self.input_port_name

    def _input_callback(self, message):
        if getattr(message, "type", "") == "note_on" and getattr(message, "velocity", 0) > 0:
            self.last_input_note = int(message.note)
            self.last_input_velocity = int(message.velocity)
            self.last_input_time = time.time()

    def get_recent_input_note(self, max_age=10.0):
        if self.last_input_note is None:
            return None
        if time.time() - self.last_input_time > max_age:
            return None
        return int(self.last_input_note)

    def close(self):
        with self.lock:
            if self.port is not None:
                self.port.close()
                self.port = None
                self.port_name = None

    def close_input(self):
        with self.lock:
            if self.input_port is not None:
                self.input_port.close()
                self.input_port = None
                self.input_port_name = None

    def note(self, note, velocity=96, length=0.08, channel=None):
        with self.lock:
            if self.port is None:
                return
            note = max(0, min(127, int(note)))
            velocity = max(1, min(127, int(velocity)))
            if channel is None:
                channel = 0
                if self.params_ref is not None:
                    try:
                        channel = int(self.params_ref.snapshot().get("midi_channel", 0))
                    except Exception:
                        channel = 0
            channel = max(0, min(15, int(channel)))
            self.port.send(mido.Message("note_on", note=note, velocity=velocity, channel=channel))
        _ch = channel
        def _off():
            time.sleep(max(0.01, float(length)))
            with self.lock:
                if self.port is not None:
                    self.port.send(mido.Message("note_off", note=note, velocity=0, channel=_ch))
        threading.Thread(target=_off, daemon=True).start()

# ─────────────────────────────────────────────────────────────────────────────
#  AI LAYER 1 — AubioAnalyzer
#  Real-time pitch (YIN), onset detection, tempo tracking
#  Requires: pip install aubio
# ─────────────────────────────────────────────────────────────────────────────

class AubioAnalyzer:
    """Real-time per-block pitch/onset/BPM via aubio."""

    def __init__(self, sample_rate, block_size):
        self.sample_rate = sample_rate
        self.block_size  = block_size
        self.bpm         = 0.0
        self._pitch  = None
        self._onset  = None
        self._tempo  = None
        self._ready  = False
        if _AUBIO:
            try:
                buf = block_size * 4
                self._pitch = _aubio_mod.pitch("yin", buf, block_size, sample_rate)
                self._pitch.set_unit("Hz")
                self._pitch.set_tolerance(0.8)
                self._onset = _aubio_mod.onset("complex", buf, block_size, sample_rate)
                self._onset.set_threshold(0.4)
                self._tempo = _aubio_mod.tempo("default", buf * 2, block_size, sample_rate)
                self._ready = True
            except Exception as exc:
                log.warning(f"AubioAnalyzer init failed: {exc}")

    def set_tolerance(self, v):
        if self._pitch is not None:
            try:
                self._pitch.set_tolerance(float(v))
            except Exception:
                pass

    def set_onset_threshold(self, v):
        if self._onset is not None:
            try:
                self._onset.set_threshold(float(v))
            except Exception:
                pass

    def analyze(self, block):
        """block: np.float32 array of length block_size.
        Returns dict: freq, confidence, onset, bpm"""
        if not self._ready:
            return {"freq": 0.0, "confidence": 0.0, "onset": False, "bpm": 0.0}
        try:
            b = block.astype(np.float32)
            if len(b) < self.block_size:
                b = np.pad(b, (0, self.block_size - len(b)))
            elif len(b) > self.block_size:
                b = b[:self.block_size]
            freq = float(self._pitch(b)[0])
            conf = float(self._pitch.get_confidence())
            onset = bool(self._onset(b)[0])
            if self._tempo(b)[0]:
                self.bpm = float(self._tempo.get_bpm())
            return {"freq": freq, "confidence": conf, "onset": onset, "bpm": self.bpm}
        except Exception:
            return {"freq": 0.0, "confidence": 0.0, "onset": False, "bpm": self.bpm}


# ─────────────────────────────────────────────────────────────────────────────
#  AI LAYER 2 — LibrosaExtractor
#  Per-event deep features: MFCCs, chroma, ZCR, rolloff, centroid
#  Runs in a background thread — never blocks the audio callback
#  Requires: pip install librosa
# ─────────────────────────────────────────────────────────────────────────────

class LibrosaExtractor:
    """Async MFCC + chroma + spectral features extractor."""

    def __init__(self):
        self._q = queue.Queue(maxsize=64)
        self._thread = threading.Thread(target=self._worker, daemon=True)
        self._thread.start()

    def submit(self, event, sample_rate, n_mfcc=13):
        """Queue an event for background feature extraction."""
        if not _LIBROSA:
            return
        try:
            self._q.put_nowait((event, sample_rate, n_mfcc))
        except queue.Full:
            pass

    def _worker(self):
        while True:
            try:
                event, sr, n_mfcc = self._q.get(timeout=1.0)
                self._process(event, sr, n_mfcc)
            except queue.Empty:
                continue
            except Exception as exc:
                log.debug(f"LibrosaExtractor worker error: {exc}")

    @staticmethod
    def _process(event, sr, n_mfcc):
        try:
            audio = event.get("audio")
            if audio is None or len(audio) < 64:
                return
            y = audio.astype(np.float32)
            mfcc = _librosa_mod.feature.mfcc(y=y, sr=sr, n_mfcc=n_mfcc)
            event["mfcc"] = np.mean(mfcc, axis=1).astype(np.float32)
            chroma = _librosa_mod.feature.chroma_stft(y=y, sr=sr)
            event["chroma"] = np.mean(chroma, axis=1).astype(np.float32)
            zcr = _librosa_mod.feature.zero_crossing_rate(y)
            event["zcr"] = float(np.mean(zcr))
            rolloff = _librosa_mod.feature.spectral_rolloff(y=y, sr=sr)
            event["rolloff"] = float(np.mean(rolloff))
            centroid = _librosa_mod.feature.spectral_centroid(y=y, sr=sr)
            event["centroid_lr"] = float(np.mean(centroid))
        except Exception as exc:
            log.debug(f"LibrosaExtractor._process error: {exc}")


# ─────────────────────────────────────────────────────────────────────────────
#  AI LAYER 3 — RAVETransformer
#  Neural audio post-processing via RAVE TorchScript model
#  Requires: pip install torch  +  a pre-trained .ts file
# ─────────────────────────────────────────────────────────────────────────────

class RAVETransformer:
    """Load and run a RAVE .ts model for neural audio transformation."""

    def __init__(self):
        self._model = None
        self._model_path = None

    def load(self, path):
        if not _TORCH:
            raise RuntimeError("torch not installed — pip install torch")
        path = str(path).strip()
        if not os.path.isfile(path):
            raise FileNotFoundError(f"RAVE model not found: {path}")
        self._model = _torch_mod.jit.load(path)
        self._model.eval()
        self._model_path = path
        log.info(f"RAVE model loaded: {path}")

    def unload(self):
        self._model = None
        self._model_path = None

    @property
    def loaded(self):
        return self._model is not None

    def transform(self, audio, sample_rate):
        """Transform audio through RAVE encode→latent→decode.
        Returns float32 array same length as input (or close)."""
        if self._model is None or not _TORCH:
            return audio
        try:
            y = audio.astype(np.float32)
            t = _torch_mod.from_numpy(y).unsqueeze(0).unsqueeze(0)  # (1,1,N)
            with _torch_mod.no_grad():
                z = self._model.encode(t)
                out = self._model.decode(z)
            result = out.squeeze().numpy()
            # Mix down to mono if RAVE returns stereo (2, N) or higher
            if result.ndim > 1:
                result = result.mean(axis=0)
            result = result.flatten()
            # Match length
            n = len(audio)
            if len(result) >= n:
                result = result[:n]
            else:
                result = np.pad(result, (0, n - len(result)))
            return result.astype(np.float32)
        except Exception as exc:
            log.debug(f"RAVETransformer.transform error: {exc}")
            return audio


# ─────────────────────────────────────────────────────────────────────────────
#  SESSION RECORDER
#  Captures the stereo mix output to WAV — dataset for RAVE training
# ─────────────────────────────────────────────────────────────────────────────

class SessionRecorder:
    """Captures TEAMMATE stereo output to WAV for RAVE training dataset."""

    def __init__(self, sample_rate=48000):
        self.sample_rate = sample_rate
        self.recording   = False
        self.chunks      = []
        self.filename    = None
        self.start_time  = None
        self.lock        = threading.Lock()

    def start(self, filepath):
        with self.lock:
            self.chunks     = []
            self.filename   = filepath
            self.start_time = time.time()
            self.recording  = True

    def process_block(self, block_stereo):
        """block_stereo: numpy (N, 2) float32 — called from output_loop."""
        if not self.recording:
            return
        with self.lock:
            self.chunks.append(block_stereo.copy())

    def stop(self):
        with self.lock:
            self.recording = False
            chunks         = list(self.chunks)
            filename       = self.filename
            elapsed        = time.time() - self.start_time if self.start_time else 0.0
            self.chunks    = []
        if not chunks or not filename:
            return 0.0, None
        threading.Thread(target=self._save, args=(chunks, filename), daemon=True).start()
        return elapsed, filename

    def _save(self, chunks, filename):
        import wave as _wave, os as _os
        audio      = np.concatenate(chunks, axis=0)          # (N, 2) float32
        audio_i16  = (np.clip(audio, -1.0, 1.0) * 32767).astype(np.int16)
        _os.makedirs(_os.path.dirname(filename), exist_ok=True)
        with _wave.open(filename, "w") as wf:
            wf.setnchannels(2)
            wf.setsampwidth(2)
            wf.setframerate(self.sample_rate)
            wf.writeframes(audio_i16.tobytes())
        mb = _os.path.getsize(filename) / (1024 * 1024)
        log.info(f"SessionRecorder saved {filename}  ({mb:.1f} MB)")

    @property
    def elapsed(self):
        if not self.recording or self.start_time is None:
            return 0.0
        return time.time() - self.start_time

    @property
    def size_mb(self):
        with self.lock:
            n = sum(len(c) for c in self.chunks)
        return (n * 4) / (1024 * 1024)   # stereo int16 = 4 bytes/frame


# ─────────────────────────────────────────────────────────────────────────────
#  POtO  —  GRANULAR SAMPLING ENGINE
# ─────────────────────────────────────────────────────────────────────────────

class GrainCloud:
    MAX_GRAINS = 512

    def __init__(self):
        self.grains = deque(maxlen=self.MAX_GRAINS)
        self.lock = threading.Lock()

    def add(self, grain):
        with self.lock:
            self.grains.append(grain)

    def clear(self):
        with self.lock:
            self.grains.clear()

    def __len__(self):
        with self.lock:
            return len(self.grains)

    def find_matches(self, freq, centroid, amp, top_k=8,
                     pitch_w=1.0, timbre_w=0.5, amp_w=0.3):
        with self.lock:
            grains = list(self.grains)
        if not grains:
            return []

        def dist(g):
            dp = (abs(g["freq"] - freq) / max(1.0, freq)
                  if g["freq"] > 0 and freq > 0 else 1.0)
            dc = abs(g["centroid"] - centroid) / 4000.0
            da = abs(g["amp"] - amp) * 4.0
            return pitch_w * dp + timbre_w * dc + amp_w * da

        ranked = sorted(grains, key=dist)
        return ranked[:min(top_k, len(ranked))]


class GrainSampler:
    def __init__(self, sample_rate, cloud, analyzer):
        self.sample_rate = sample_rate
        self.cloud = cloud
        self.analyzer = analyzer
        self.buffer = np.array([], dtype=np.float32)
        self.recording = False

    def start(self):
        self.buffer = np.array([], dtype=np.float32)
        self.recording = True

    def stop(self):
        self.recording = False
        self.buffer = np.array([], dtype=np.float32)

    def process_block(self, block, grain_ms):
        if not self.recording:
            return
        grain_size = max(64, int((grain_ms / 1000.0) * self.sample_rate))
        self.buffer = np.concatenate([self.buffer, block])
        while len(self.buffer) >= grain_size:
            grain_audio = self.buffer[:grain_size].copy()
            self.buffer = self.buffer[grain_size:]
            feat = self.analyzer.analyze(grain_audio, self.sample_rate)
            if feat["rms"] > 0.005:
                self.cloud.add({
                    "audio":    grain_audio,
                    "freq":     feat["freq"],
                    "centroid": feat["centroid"],
                    "amp":      feat["rms"],
                    "midi_note": feat["midi_note"],
                })


def _grain_envelope(audio):
    if len(audio) < 4:
        return audio.copy()
    return (audio * np.hanning(len(audio)).astype(np.float32))


class POtOEngine:
    def __init__(self, cloud, mixer, params_ref, poto_midi_manager=None, midi_fallback=None):
        self.cloud = cloud
        self.mixer = mixer
        self.params_ref = params_ref
        self.poto_midi_manager = poto_midi_manager
        self.midi_fallback = midi_fallback   # shared port fallback when poto port not opened
        self.last_trigger = 0.0
        self.last_trigger_tm = 0.0  # separate cooldown for teammate input

    def process(self, features):
        params = self.params_ref.snapshot()
        if not params.get("poto_enabled", False):
            return
        if params.get("poto_input_mode", "mic") == "teammate":
            return  # mic input disabled in teammate-only mode
        if params.get("teammate_strategy", "NONE") == "SILENCE":
            return  # respect teammate silence
        if len(self.cloud) < 4:
            return
        if features["rms"] < 0.01:
            return

        now = time.time()
        interval = max(0.01, float(params.get("poto_trigger_interval", 0.08)))
        if now - self.last_trigger < interval:
            return
        self.last_trigger = now
        self._trigger_grains(features, params)

    def _trigger_grains(self, features, params):
        """Shared grain selection + playback logic."""
        n_voices = max(1, int(params.get("poto_voices", 3)))
        pitch_w  = float(params.get("poto_pitch_weight", 1.0))
        timbre_w = float(params.get("poto_timbre_weight", 0.5))
        amp_w    = float(params.get("poto_amp_weight", 0.3))
        spread   = float(params.get("poto_chord_spread", 0.015))
        gain     = float(params.get("master_gain", 0.8)) * float(params.get("poto_gain", 0.70))
        max_v    = int(params.get("max_simultaneous_voices", 12))
        pool_size = max(n_voices * 4, 24)
        pool = self.cloud.find_matches(
            features["freq"], features["centroid"], features["rms"],
            top_k=pool_size, pitch_w=pitch_w, timbre_w=timbre_w, amp_w=amp_w,
        )
        if not pool:
            return
        chord = [(pool[0], gain)]
        if n_voices > 1:
            n_others    = n_voices - 1
            n_attracted = (n_others + 1) // 2
            n_repulsed  = n_others - n_attracted
            attracted = pool[1 : 1 + n_attracted]
            repulsed  = pool[max(1, len(pool) - n_repulsed):] if n_repulsed > 0 else []
            ai = ri = 0
            for i in range(n_others):
                if i % 2 == 0 and ai < len(attracted):
                    chord.append((attracted[ai], gain * random.uniform(0.55, 0.80))); ai += 1
                elif ri < len(repulsed):
                    chord.append((repulsed[ri],  gain * random.uniform(0.35, 0.60))); ri += 1
                elif ai < len(attracted):
                    chord.append((attracted[ai], gain * random.uniform(0.55, 0.80))); ai += 1
        # POtO MIDI out — one note per chord voice, freq→pitch, amp→velocity
        pmm = self.poto_midi_manager
        # Use dedicated poto port if open, else fall back to the shared midi_manager port
        if (pmm is None or pmm.port is None) and self.midi_fallback is not None:
            pmm = self.midi_fallback
        poto_midi_on = pmm is not None and pmm.port is not None and params.get("poto_midi_enabled", False)
        if poto_midi_on:
            import math as _m
            poto_ch = max(0, min(15, int(params.get("poto_midi_channel", 1)) - 1))
            note_len = float(params.get("poto_midi_note_length", 0.08))

        for i, (grain, g) in enumerate(chord):
            threading.Thread(target=self._play, args=(grain["audio"], g, i * spread, max_v), daemon=True).start()
            if poto_midi_on:
                fv = grain.get("freq", 0.0)
                if fv > 0:
                    raw_note = 69 + 12 * _m.log2(fv / 440.0)
                    midi_note = max(0, min(127, int(round(raw_note))))
                    vel = max(1, min(127, int(grain.get("amp", 0.5) * 127 * float(params.get("midi_velocity_scale", 1.0)))))
                    delay_s = i * spread
                    def _send_midi(n=midi_note, v=vel, d=delay_s):
                        if d > 0:
                            time.sleep(d)
                        pmm.note(n, v, note_len, channel=poto_ch)
                    threading.Thread(target=_send_midi, daemon=True).start()

    def _play(self, audio, gain, delay, max_voices):
        if delay > 0:
            time.sleep(delay)
        self.mixer.trigger(_grain_envelope(audio), gain, max_voices)

    def process_teammate(self, features):
        """Driven by TEAMMATE output — active when poto_input_mode is 'teammate' or 'both'."""
        params = self.params_ref.snapshot()
        if not params.get("poto_enabled", False):
            return
        mode = params.get("poto_input_mode", "mic")
        if mode == "mic":
            return  # teammate input disabled
        if params.get("teammate_strategy", "NONE") == "SILENCE":
            return  # respect teammate silence
        if len(self.cloud) < 4:
            return
        if features["rms"] < 0.005:
            return
        now = time.time()
        interval = max(0.01, float(params.get("poto_trigger_interval", 0.08)))
        if now - self.last_trigger_tm < interval:
            return
        self.last_trigger_tm = now
        # Run the same grain selection + playback
        self._trigger_grains(features, params)


class AudioEngine:
    def __init__(self, input_queue, output_queue, sample_rate, block_size, input_device=None, output_device=None, params_ref=None):
        self.input_queue = input_queue
        self.output_queue = output_queue
        self.sample_rate = sample_rate
        self.block_size = block_size
        self.input_device = input_device
        self.output_device = output_device
        self.params_ref = params_ref
        self.stream = None
    def start(self):
        self.stream = sd.Stream(
            samplerate=self.sample_rate,
            blocksize=self.block_size,
            dtype="float32",
            channels=(INPUT_CHANNELS, OUTPUT_CHANNELS),
            callback=self._callback,
            device=(self.input_device, self.output_device),
        )
        self.stream.start()
    def stop(self):
        if self.stream is not None:
            self.stream.stop()
            self.stream.close()
            self.stream = None

    def set_devices(self, input_device=None, output_device=None):
        prev_in  = self.input_device
        prev_out = self.output_device
        self.stop()
        if input_device is not None:
            self.input_device = input_device
        if output_device is not None:
            self.output_device = output_device
        try:
            self.start()
            log.info(f"AudioEngine started — in={self.input_device} out={self.output_device}")
        except Exception as e:
            print(f"    audio error: {e}")
            print(f"    reverting to previous devices")
            _log_exception(f"AudioEngine.set_devices in={self.input_device} out={self.output_device}")
            self.input_device  = prev_in
            self.output_device = prev_out
            try:
                self.start()
                log.info(f"AudioEngine reverted — in={self.input_device} out={self.output_device}")
            except Exception as e2:
                log.error(f"AudioEngine revert failed: {e2}")

    def _callback(self, indata, outdata, frames, time_info, status):
        mono_in = indata[:, 0].copy()
        try:
            self.input_queue.put_nowait(mono_in)
        except queue.Full:
            pass
        teammate_out = np.zeros((frames, 2), dtype=np.float32)
        try:
            raw = self.output_queue.get_nowait()
            if raw.ndim == 2 and raw.shape[1] == 2:
                teammate_out = raw
            else:
                teammate_out[:, 0] = raw
                teammate_out[:, 1] = raw
        except queue.Empty:
            pass
        params = self.params_ref.snapshot() if self.params_ref is not None else {}
        final_out = np.zeros((frames, 2), dtype=np.float32)
        ghost = params.get("ghost_mode", False)
        if params.get("input_monitor_enabled", True) and not ghost:
            gain = float(params.get("input_monitor_gain", 1.0))
            final_out[:, 0] += mono_in * gain
            final_out[:, 1] += mono_in * gain
        if params.get("audio_enabled", True):
            final_out += teammate_out * float(params.get("teammate_output_gain", 1.0))
        final_out = np.clip(final_out, -1.0, 1.0)
        outdata[:, 0] = final_out[:, 0]
        outdata[:, 1] = final_out[:, 1]

class AudioAnalyzer:
    def __init__(self):
        self.prev_rms = 0.0
    def analyze(self, data, sr):
        if len(data) == 0:
            return {"rms": 0.0, "onset": False, "freq": 0.0, "centroid": 0.0, "note": None, "midi_note": None, "duration_ms": 0.0}
        x = data.astype(np.float64)
        rms = float(np.sqrt(np.mean(x * x) + 1e-12))
        onset = (rms - self.prev_rms) > ONSET_THRESHOLD
        self.prev_rms = rms
        window = np.hanning(len(x))
        spec = np.fft.rfft(x * window)
        mag = np.abs(spec)
        freqs = np.fft.rfftfreq(len(x), 1.0 / sr)
        peak_idx = int(np.argmax(mag[1:]) + 1) if len(mag) > 1 and np.max(mag) > 1e-9 else 0
        freq = float(freqs[peak_idx]) if peak_idx > 0 else 0.0
        mag_sum = float(np.sum(mag))
        centroid = float(np.sum(freqs * mag) / mag_sum) if mag_sum > 1e-9 else 0.0
        note = None
        midi_note = None
        if freq > 40:
            midi_note = int(round(69 + 12 * np.log2(freq / 440.0)))
            midi_note = max(0, min(127, midi_note))
            names = ["C","C#","D","D#","E","F","F#","G","G#","A","A#","B"]
            note = f"{names[midi_note % 12]}{(midi_note // 12) - 1}"
        return {"rms": rms, "onset": onset, "freq": freq, "centroid": centroid, "note": note, "midi_note": midi_note, "duration_ms": (len(data) / sr) * 1000.0}

class IntentAnalyzer:
    def __init__(self, maxlen=64):
        self.history = deque(maxlen=maxlen)
    def update(self, features):
        self.history.append(features)
        if len(self.history) < 12:
            return {"start": 0.0, "end": 0.0, "continuation": 0.0}
        rms_vals = [f["rms"] for f in self.history]
        onset_vals = [1.0 if f["onset"] else 0.0 for f in self.history]
        recent_rms = sum(rms_vals[-6:]) / 6.0
        older_rms = sum(rms_vals[-18:-6]) / 12.0
        recent_onsets = sum(onset_vals[-6:])
        older_onsets = sum(onset_vals[-18:-6])
        start = max(0.0, recent_rms - older_rms) * 12.0 + max(0.0, recent_onsets - older_onsets) * 0.12
        end = max(0.0, older_rms - recent_rms) * 12.0
        if recent_rms < 0.008:
            end += 0.35
        continuation = max(0.0, min(1.0, recent_rms * 18.0))
        return {"start": min(1.0, start), "end": min(1.0, end), "continuation": min(1.0, continuation)}


class StructureAnalyzer:
    """Tracks the macro arc of the performance over ~60s.
    Detects phases INTRO/BUILD/PEAK/DECAY/SILENCE and outputs
    additive strategy biases for PhrasePlanner.choose_strategy."""

    PHASES = ("INTRO", "BUILD", "PEAK", "DECAY", "SILENCE")
    _BIAS  = {
        "INTRO":   {"IMITATION": 0.10, "CONTRASTE": 0.05, "DENSIFICATION":-0.10, "SPARSE": 0.15, "SILENCE": 0.10},
        "BUILD":   {"IMITATION": 0.05, "CONTRASTE": 0.05, "DENSIFICATION": 0.20, "SPARSE":-0.05, "SILENCE":-0.10},
        "PEAK":    {"IMITATION": 0.05, "CONTRASTE": 0.15, "DENSIFICATION": 0.30, "SPARSE":-0.15, "SILENCE":-0.20},
        "DECAY":   {"IMITATION": 0.10, "CONTRASTE":-0.05, "DENSIFICATION":-0.15, "SPARSE": 0.20, "SILENCE": 0.15},
        "SILENCE": {"IMITATION": 0.00, "CONTRASTE":-0.10, "DENSIFICATION":-0.20, "SPARSE": 0.10, "SILENCE": 0.30},
    }

    def __init__(self, coarse_interval=0.5, window_sec=60):
        self.coarse_interval = coarse_interval
        self.window_size = int(window_sec / coarse_interval)
        self.rms_buf    = deque(maxlen=self.window_size)
        self._acc_rms   = []
        self._acc_onset = []
        self._last_tick = 0.0
        self.phase      = "INTRO"
        self.trend      = "STABLE"
        self._hold      = 0   # ticks before phase can change again

    def update(self, features):
        now = time.time()
        self._acc_rms.append(features["rms"])
        self._acc_onset.append(1.0 if features["onset"] else 0.0)
        if now - self._last_tick >= self.coarse_interval:
            self._last_tick = now
            if self._acc_rms:
                self.rms_buf.append(sum(self._acc_rms) / len(self._acc_rms))
                self._acc_rms.clear()
                self._acc_onset.clear()
            if len(self.rms_buf) >= 4:
                self._compute()

    def _compute(self):
        buf = list(self.rms_buf)
        n   = len(buf)
        avg    = sum(buf) / n
        recent = sum(buf[max(0, n - 4):]) / min(4, n)
        old    = sum(buf[:max(1, n // 3)]) / max(1, n // 3)
        if recent > old * 1.25:
            self.trend = "ASCENDING"
        elif recent < old * 0.75:
            self.trend = "DESCENDING"
        else:
            self.trend = "STABLE"
        if self._hold > 0:
            self._hold -= 1
            return
        if avg < 0.008:
            new = "SILENCE"
        elif avg > 0.12 and self.trend in ("ASCENDING", "STABLE"):
            new = "PEAK"
        elif self.trend == "ASCENDING" and avg > 0.03:
            new = "BUILD"
        elif self.trend == "DESCENDING" and avg > 0.008:
            new = "DECAY"
        else:
            new = "INTRO"
        if new != self.phase:
            self.phase = new
            self._hold = 4

    def get_bias(self):
        return dict(self._BIAS.get(self.phase, {}))

    def status_str(self):
        buf = list(self.rms_buf)
        avg = sum(buf) / len(buf) if buf else 0.0
        return (f"  phase={self.phase}  trend={self.trend}"
                f"  avg_rms={avg:.4f}  window={len(buf)}/{self.window_size}")


class StyleProfiler:
    """Learns playing habits across sessions and persists them to JSON.
    Tracks tessiture, dynamics, event density, and silence tendencies.
    After 2+ sessions it can suggest calibrated params."""

    def __init__(self, profile_path):
        self.profile_path   = profile_path
        self._freq          = [0] * 128
        self._rms_list      = []
        self._event_count   = 0
        self._session_start = time.time()
        self._last_evt_time = None
        self._silence_gaps  = []
        self.cumulative     = self._load()

    def _load(self):
        try:
            import json as _j, os as _o
            if _o.path.isfile(self.profile_path):
                with open(self.profile_path) as f:
                    d = _j.load(f)
                log.info(f"StyleProfiler loaded  sessions={d.get('session_count', 0)}")
                return d
        except Exception as e:
            log.debug(f"StyleProfiler load: {e}")
        return {"session_count": 0, "freq_hist": [0]*128,
                "avg_rms": 0.05, "avg_density": 10.0,
                "avg_silence_gap": 2.0, "avg_silence_bias": 0.3}

    def observe_event(self, event):
        mn = event.get("midi_note")
        if mn is not None and 0 <= mn < 128:
            self._freq[mn] += 1
        rms = event.get("rms", 0.0)
        if rms > 0:
            self._rms_list.append(rms)
        now = time.time()
        if self._last_evt_time is not None:
            gap = now - self._last_evt_time
            if gap > 0.5:
                self._silence_gaps.append(gap)
        self._last_evt_time = now
        self._event_count  += 1

    def save_session(self):
        try:
            import json as _j, os as _o
            dur          = max(1.0, time.time() - self._session_start)
            density      = (self._event_count / dur) * 60.0
            avg_rms      = sum(self._rms_list) / len(self._rms_list) if self._rms_list else 0.05
            avg_gap      = sum(self._silence_gaps) / len(self._silence_gaps) if self._silence_gaps else 2.0
            sil_bias     = max(0.05, min(0.9, 1.0 - min(1.0, density / 30.0)))
            n            = max(1, self.cumulative.get("session_count", 0))
            a            = 1.0 / (n + 1)
            c            = self.cumulative
            c["session_count"]   = n + 1
            c["avg_rms"]         = c.get("avg_rms", avg_rms) * (1-a) + avg_rms * a
            c["avg_density"]     = c.get("avg_density", density) * (1-a) + density * a
            c["avg_silence_gap"] = c.get("avg_silence_gap", avg_gap) * (1-a) + avg_gap * a
            c["avg_silence_bias"]= c.get("avg_silence_bias", sil_bias) * (1-a) + sil_bias * a
            h = c.get("freq_hist", [0]*128)
            for i in range(128):
                h[i] = int(h[i] * (1-a) + self._freq[i] * a)
            c["freq_hist"] = h
            _o.makedirs(_o.path.dirname(self.profile_path), exist_ok=True)
            with open(self.profile_path, "w") as f:
                _j.dump(c, f, indent=2)
            log.info(f"StyleProfiler saved  sessions={n+1}")
        except Exception as e:
            log.debug(f"StyleProfiler save: {e}")

    def get_suggested_params(self):
        c = self.cumulative
        if c.get("session_count", 0) < 2:
            return {}
        density  = max(0.1, min(0.95, c.get("avg_density", 10.0) / 40.0))
        reply    = max(0.2, min(0.95, 0.4 + density * 0.5))
        sil_bias = max(0.05, min(0.8, c.get("avg_silence_bias", 0.3)))
        return {"density": round(density, 2),
                "reply_probability": round(reply, 2),
                "silence_bias": round(sil_bias, 2)}

    def status_str(self):
        c = self.cumulative
        n = c.get("session_count", 0)
        if n == 0:
            return "  no data yet — play more sessions"
        names  = ["C","C#","D","D#","E","F","F#","G","G#","A","A#","B"]
        hist   = c.get("freq_hist", [0]*128)
        top5   = sorted(range(128), key=lambda i: hist[i], reverse=True)[:5]
        top_s  = "  ".join(f"{names[i%12]}{i//12-1}" for i in top5)
        sug    = self.get_suggested_params()
        lines  = [
            f"  sessions       = {n}",
            f"  tessiture      = {top_s}",
            f"  density        = {c.get('avg_density', 0):.1f} events/min",
            f"  avg_rms        = {c.get('avg_rms', 0):.4f}",
            f"  silence gap    = {c.get('avg_silence_gap', 0):.2f}s avg",
        ]
        if sug:
            lines += ["  — suggested —",
                      f"  density        = {sug['density']}",
                      f"  reply_prob     = {sug['reply_probability']}",
                      f"  silence_bias   = {sug['silence_bias']}"]
        else:
            lines.append("  (play 2+ sessions for suggestions)")
        return "\n".join(lines)


class LearningModel:
    def __init__(self, rate=0.08):
        self.rate = rate
        self.avg_rms = 0.0
        self.avg_freq = 0.0
    def update_features(self, features):
        self.avg_rms = features["rms"] if self.avg_rms == 0.0 else self.avg_rms + (features["rms"] - self.avg_rms) * self.rate
        if features["freq"] > 0:
            self.avg_freq = features["freq"] if self.avg_freq == 0.0 else self.avg_freq + (features["freq"] - self.avg_freq) * self.rate

class Segmenter:
    def __init__(self, sample_rate):
        self.sample_rate = sample_rate
        self.current = []
        self.active = False
        self.segment_start_time = 0.0
        self.last_non_silent_time = 0.0
    def process_block(self, block, block_time):
        events = []
        level = float(np.sqrt(np.mean(block.astype(np.float64) ** 2) + 1e-12))
        if level >= RMS_THRESHOLD:
            if not self.active:
                self.active = True
                self.current = []
                self.segment_start_time = block_time
            self.current.append(block.copy())
            self.last_non_silent_time = block_time
        elif self.active:
            self.current.append(block.copy())
        if self.active:
            total_samples = sum(len(b) for b in self.current)
            total_ms = (total_samples / self.sample_rate) * 1000.0
            silent_too_long = (block_time - self.last_non_silent_time) * 1000.0 > SILENCE_HOLD_MS
            max_len_reached = total_ms >= MAX_SEGMENT_MS
            if silent_too_long or max_len_reached:
                audio = np.concatenate(self.current) if self.current else np.array([], dtype=np.float32)
                self.current = []
                self.active = False
                if len(audio) > 0 and total_ms >= MIN_SEGMENT_MS:
                    events.append((self.segment_start_time, audio))
        return events

class EphemeralCorpus:
    def __init__(self):
        self.events = deque(maxlen=MAX_CORPUS_EVENTS)
    def add(self, event):
        self.events.append(event)
    def clear(self):
        self.events.clear()
    def __len__(self):
        return len(self.events)
    def get_random(self):
        return random.choice(list(self.events)) if self.events else None
    def _distance(self, ev, target, weights):
        dr = abs(ev["rms"] - target["rms"]) * 4.0
        df = abs(ev["freq"] - target["freq"]) / 1000.0 if ev["freq"] > 0 and target["freq"] > 0 else 1.0
        dc = abs(ev["centroid"] - target["centroid"]) / 4000.0
        dd = abs(ev.get("duration_ms", 0.0) - target.get("duration_ms", 0.0)) / 1200.0
        base = weights["energy"]*dr + weights["pitch"]*df + weights["timbre"]*dc + weights["duration"]*dd
        # MFCC cosine distance (librosa layer)
        mfcc_w = weights.get("mfcc", 0.0)
        if mfcc_w > 0.0:
            ev_mfcc  = ev.get("mfcc")
            tgt_mfcc = target.get("mfcc")
            if ev_mfcc is not None and tgt_mfcc is not None:
                dot  = float(np.dot(ev_mfcc, tgt_mfcc))
                norm = float(np.linalg.norm(ev_mfcc) * np.linalg.norm(tgt_mfcc))
                if norm > 1e-9:
                    base += mfcc_w * (1.0 - dot / norm)
        return base
    def get_best_match(self, target, exclude_ids=None):
        exclude_ids = exclude_ids or set()
        ranked = [ev for ev in self.events if ev.get("id") not in exclude_ids]
        ranked.sort(key=lambda ev: self._distance(ev, target, {"timbre":1.0,"pitch":0.35,"duration":0.25,"energy":0.45,"mfcc":0.0}))
        return random.choice(ranked[:min(6, len(ranked))]) if ranked else None
    def get_contrasting(self, target, exclude_ids=None):
        exclude_ids = exclude_ids or set()
        ranked = [ev for ev in self.events if ev.get("id") not in exclude_ids]
        ranked.sort(key=lambda ev: self._distance(ev, target, {"timbre":1.0,"pitch":0.35,"duration":0.25,"energy":0.45,"mfcc":0.0}), reverse=True)
        return random.choice(ranked[:min(6, len(ranked))]) if ranked else None
    def get_calltrans_matches(self, target, exclude_ids=None, top_k=6, weights=None):
        exclude_ids = exclude_ids or set()
        weights = weights or {"timbre":1.0,"pitch":0.35,"duration":0.25,"energy":0.45,"mfcc":0.0}
        ranked = [ev for ev in self.events if ev.get("id") not in exclude_ids]
        ranked.sort(key=lambda ev: self._distance(ev, target, weights))
        return ranked[:max(1, min(int(top_k), len(ranked)))]

class RecentMemory:
    def __init__(self, maxlen=24):
        self.last_heard = deque(maxlen=maxlen)
        self.last_played = deque(maxlen=maxlen)
    def note_heard(self, event_id):
        self.last_heard.append(event_id)
    def note_played(self, event_id):
        self.last_played.append(event_id)
    def played_set(self):
        return set(self.last_played)
    def clear(self):
        self.last_heard.clear()
        self.last_played.clear()

class SampleVoice:
    def __init__(self, audio, gain=1.0, pan=0.0):
        self.audio = audio.astype(np.float32)
        self.gain = float(gain)
        self.pan = float(max(-1.0, min(1.0, pan)))
        self.pos = random.uniform(0.0, 10.0)
    def is_done(self):
        return self.pos >= (len(self.audio) - 1)
    def render(self, frames):
        if self.is_done() or len(self.audio) < 2:
            return np.zeros(frames, dtype=np.float32)
        out = np.zeros(frames, dtype=np.float32)
        total_len = len(self.audio)
        fade_samples = int(min(total_len * 0.1, 0.005 * 48000))
        fade_samples = max(1, fade_samples)
        for i in range(frames):
            if self.pos >= (total_len - 1):
                break
            i0 = int(self.pos)
            frac = self.pos - i0
            sample = (1.0 - frac) * self.audio[i0] + frac * self.audio[i0 + 1]
            amp = 1.0
            if i0 < fade_samples:
                amp *= i0 / fade_samples
            if i0 > total_len - fade_samples:
                amp *= max(0.0, (total_len - i0) / fade_samples)
            out[i] = sample * self.gain * amp
            self.pos += 1.0
        return out

class OutputMixer:
    def __init__(self, block_size):
        self.block_size = block_size
        self.voices = []
        self.lock = threading.Lock()
    def trigger(self, audio, gain=0.7, max_voices=8, pan=None):
        if pan is None:
            pan = random.uniform(-0.75, 0.75)
        with self.lock:
            if len(self.voices) >= max_voices:
                self.voices.pop(0)
            self.voices.append(SampleVoice(audio=audio, gain=gain * random.uniform(0.7, 1.0), pan=pan))
    def clear(self):
        with self.lock:
            self.voices.clear()
    def render_block(self, compress_mode="off"):
        with self.lock:
            block = np.zeros((self.block_size, 2), dtype=np.float32)
            alive = []
            for voice in self.voices:
                mono = voice.render(self.block_size)
                # equal-power panning
                angle = (voice.pan + 1.0) * np.pi / 4.0  # 0..pi/2
                block[:, 0] += mono * float(np.cos(angle))
                block[:, 1] += mono * float(np.sin(angle))
                if not voice.is_done():
                    alive.append(voice)
            self.voices = alive
        if compress_mode == "gentle":
            block = np.tanh(block * 1.4) / np.tanh(1.4)
        elif compress_mode == "hard":
            block = np.tanh(block * 2.4) / np.tanh(2.4)
        elif compress_mode == "ambient":
            rms = float(np.sqrt(np.mean(block.astype(np.float64) ** 2) + 1e-12))
            if rms > 1e-6:
                block = block * min(2.5, 0.18 / rms)
            block = np.tanh(block * 2.0) / np.tanh(2.0)
        block = np.clip(block, -1.0, 1.0)
        max_val = float(np.max(np.abs(block))) + 1e-6
        if max_val > 0.9:
            block = block / max_val * 0.9
        return block.astype(np.float32)


class PositionMapper:
    def __init__(self, params_ref, midi_manager):
        self.params_ref = params_ref
        self.midi_manager = midi_manager
    def _window_bounds(self, corpus_len):
        if corpus_len <= 0:
            return (0, 0)
        snap = self.params_ref.snapshot()
        start = int(round(max(0.0, min(1.0, snap.get("corpus_window_start", 0.0))) * max(0, corpus_len - 1)))
        end = int(round(max(0.0, min(1.0, snap.get("corpus_window_end", 1.0))) * max(0, corpus_len - 1)))
        if end < start:
            end = start
        return start, end
    def preferred_events(self, corpus_events):
        snap = self.params_ref.snapshot()
        if not snap.get("midi_note_in_enabled", False):
            return []
        note = self.midi_manager.get_recent_input_note()
        if note is None or not corpus_events:
            return []
        lo = int(snap.get("midi_note_in_min", 36))
        hi = int(snap.get("midi_note_in_max", 96))
        if hi <= lo:
            hi = lo + 1
        note = max(lo, min(hi, int(note)))
        norm = (note - lo) / float(hi - lo)
        start, end = self._window_bounds(len(corpus_events))
        target = int(round(start + norm * max(0, end - start)))
        radius = max(0, int(snap.get("position_window_radius", 6)))
        low = max(start, target - radius)
        high = min(end, target + radius)
        return list(corpus_events)[low:high + 1]
    def map_event_to_output_note(self, event, corpus_events):
        snap = self.params_ref.snapshot()
        if not snap.get("midi_note_out_enabled", False):
            return event.get("midi_note")
        if not corpus_events:
            return event.get("midi_note")
        items = list(corpus_events)
        try:
            idx = items.index(event)
        except ValueError:
            return event.get("midi_note")
        start, end = self._window_bounds(len(items))
        if end <= start:
            return int(snap.get("midi_note_out_min", 36))
        idx = max(start, min(end, idx))
        norm = (idx - start) / float(end - start)
        lo = int(snap.get("midi_note_out_min", 36))
        hi = int(snap.get("midi_note_out_max", 96))
        if hi <= lo:
            hi = lo + 1
        return int(round(lo + norm * (hi - lo)))

class PhrasePlanner:
    def __init__(self, corpus, position_mapper=None):
        self.corpus = corpus
        self.position_mapper = position_mapper
        self.last_weights = {}
        self.last_factors  = {}
    def choose_strategy(self, features, intent, params, corpus_size, context=None):
        energy = min(1.0, features["rms"] * 10.0)
        brightness = min(1.0, features["centroid"] / 4000.0)
        weights = {
            "IMITATION": 0.25 + energy * 0.12,
            "CONTRASTE": 0.15 + params["contrast_amount"] * 0.35 + brightness * 0.1,
            "DENSIFICATION": 0.12 + params["density"] * 0.35 + intent["continuation"] * 0.12,
            "SPARSE": 0.18 + params["silence_bias"] * 0.2 + intent["end"] * 0.15,
            "SILENCE": params["silence_bias"],
        }
        reasons = []
        if corpus_size < 8:
            weights["IMITATION"] += 0.15
            weights["DENSIFICATION"] -= 0.06
            reasons.append(f"small_corpus({corpus_size})")
        if energy > 0.5:
            reasons.append(f"high_energy({energy:.2f})")
        # smart silence context
        if context:
            consec = context.get("consecutive_silences", 0)
            input_silent_sec = context.get("input_silent_sec", 0.0)
            last = context.get("last_strategy", "NONE")
            # penalise consecutive silences strongly
            if consec >= 2:
                weights["SILENCE"] *= 0.15
                reasons.append(f"consec_sil={consec}→penalise")
            elif consec == 1:
                weights["SILENCE"] *= 0.45
            # mirror player silence briefly, don't overwhelm
            if input_silent_sec > 3.0:
                weights["SILENCE"] += 0.25
                weights["IMITATION"] *= 0.4
                weights["DENSIFICATION"] *= 0.3
                reasons.append(f"input_sil>{input_silent_sec:.1f}s")
            elif input_silent_sec > 1.5:
                weights["SILENCE"] += 0.1
            # breathe after density
            if last == "DENSIFICATION":
                weights["SPARSE"] += 0.25
                weights["SILENCE"] += 0.18
                weights["DENSIFICATION"] *= 0.2
                reasons.append("after_dense→breathe")
            # structure phase bias (additive, from StructureAnalyzer)
            bias = context.get("structure_bias", {})
            if bias:
                for _k, _v in bias.items():
                    if _k in weights:
                        weights[_k] = weights[_k] + _v
                phase = context.get("structure_phase", "")
                if phase:
                    reasons.append(f"phase={phase}")
        total = sum(max(0.0, v) for v in weights.values())
        norm  = {k: max(0.0, v) / total for k, v in weights.items()} if total > 0 else weights
        self.last_weights = norm
        self.last_factors = {
            "energy": round(energy, 3),
            "brightness": round(brightness, 3),
            "intent.end": round(intent.get("end", 0), 3),
            "intent.cont": round(intent.get("continuation", 0), 3),
            "density": round(params.get("density", 0), 3),
            "silence_bias": round(params.get("silence_bias", 0), 3),
            "corpus": corpus_size,
            "reasons": reasons,
        }
        pick = random.random() * total
        accum = 0.0
        for k, v in weights.items():
            accum += max(0.0, v)
            if pick <= accum:
                return k
        return "IMITATION"
    def _calltrans_weights(self, params):
        return {
            "timbre": params["calltrans_timbre_weight"],
            "pitch": params["calltrans_pitch_weight"],
            "duration": params["calltrans_duration_weight"],
            "energy": params["calltrans_energy_weight"],
            "mfcc": params.get("librosa_mfcc_weight", 0.0) if params.get("librosa_enabled", False) else 0.0,
        }
    def _calltrans_phrase(self, features, params, memory, count):
        matches = self.corpus.get_calltrans_matches(features, memory.played_set(), params["calltrans_top_k"], self._calltrans_weights(params))
        return [random.choice(matches) for _ in range(count)] if matches else []
    def build_phrase(self, strategy, features, params, memory):
        count = random.randint(params["phrase_min_events"], params["phrase_max_events"])
        preferred = self.position_mapper.preferred_events(self.corpus.events) if self.position_mapper is not None else []
        if strategy == "SPARSE":
            count = min(count, 3)
        elif strategy == "DENSIFICATION":
            count = max(count, min(params["phrase_max_events"], 5))
        planned, used = [], set(memory.played_set())
        for _ in range(count):
            if preferred:
                candidates = [ev for ev in preferred if ev.get("id") not in used] or list(preferred)
                ev = random.choice(candidates) if candidates else None
            elif strategy == "IMITATION":
                ev = self.corpus.get_best_match(features, used)
            elif strategy == "CONTRASTE":
                ev = self.corpus.get_contrasting(features, used)
            elif strategy == "DENSIFICATION":
                ev = self.corpus.get_best_match(features)
            else:
                ev = self.corpus.get_random()
            if ev is None:
                continue
            used.add(ev.get("id"))
            planned.append(ev)
        if params["calltrans_enabled"]:
            trans_count = max(1, int(round(count * max(0.0, min(1.0, params["calltrans_amount"])))))
            trans_phrase = self._calltrans_phrase(features, params, memory, trans_count)
            if params["calltrans_follow_input_only"]:
                planned = trans_phrase[:count]
            elif trans_phrase:
                replace_count = min(len(planned), len(trans_phrase), trans_count)
                if replace_count == 0 and not planned:
                    planned = trans_phrase[:count]
                else:
                    planned = (planned[:max(0, len(planned)-replace_count)] + trans_phrase[:replace_count])[: params["phrase_max_events"]]
        return planned


class SwarmReader:
    def __init__(self, mixer, params_ref):
        self.mixer = mixer
        self.params_ref = params_ref
        self.target = None
        self.smooth_target = None
        self.last_emit = 0.0

    def update_target(self, features):
        params = self.params_ref.snapshot()
        self.target = {
            "rms": float(features.get("rms", 0.0)),
            "freq": float(features.get("freq", 0.0)),
            "centroid": float(features.get("centroid", 0.0)),
            "duration_ms": float(features.get("duration_ms", 0.0)),
        }
        if self.smooth_target is None:
            self.smooth_target = dict(self.target)
        else:
            inertia = max(0.0, min(0.99, float(params.get("swarm_follow_inertia", 0.65))))
            blend = 1.0 - inertia
            for k in ("rms", "freq", "centroid", "duration_ms"):
                self.smooth_target[k] = self.smooth_target[k] * inertia + self.target[k] * blend

    def _distance(self, ev, target, params):
        ew = float(params.get("swarm_follow_energy_weight", 0.55))
        pw = float(params.get("swarm_follow_pitch_weight", 0.35))
        cw = float(params.get("swarm_follow_centroid_weight", 1.0))
        dr = abs(ev["rms"] - target["rms"]) * 4.0
        df = abs(ev["freq"] - target["freq"]) / 1000.0 if ev["freq"] > 0 and target["freq"] > 0 else 1.0
        dc = abs(ev["centroid"] - target["centroid"]) / 4000.0
        return ew * dr + pw * df + cw * dc

    def pick_live_targets(self, corpus_events):
        params = self.params_ref.snapshot()
        if not corpus_events or self.smooth_target is None:
            return []
        ranked = list(corpus_events)
        ranked.sort(key=lambda ev: self._distance(ev, self.smooth_target, params))
        top_k = max(1, min(int(params.get("swarm_follow_top_k", 8)), len(ranked)))
        best = ranked[:top_k]
        mode = str(params.get("swarm_follow_mode", "FOLLOW")).upper()
        count = max(1, int(params.get("swarm_count", 4)))
        out = []
        if mode == "FOLLOW":
            for _ in range(count):
                out.append(random.choice(best))
        elif mode == "DRIFT":
            spread = ranked[:max(top_k, min(len(ranked), top_k * 2))]
            for i in range(count):
                bank = best if i % 2 == 0 else spread
                out.append(random.choice(bank))
        elif mode == "SPLIT":
            contrast = ranked[-top_k:] if len(ranked) >= top_k else ranked
            for i in range(count):
                bank = best if i < max(1, count // 2) else contrast
                out.append(random.choice(bank))
        elif mode == "GHOST":
            ghost_bank = ranked[min(len(ranked)-1, top_k):min(len(ranked), top_k * 3)] or best
            for i in range(count):
                bank = ghost_bank if i % 2 == 0 else best
                out.append(random.choice(bank))
        else:
            for _ in range(count):
                out.append(random.choice(best))
        return out

    def process_live_follow(self, corpus_events):
        params = self.params_ref.snapshot()
        if not params.get("swarm_enabled", False):
            return
        if not params.get("swarm_follow_live", False):
            return
        now = time.time()
        update_sec = max(0.02, float(params.get("swarm_follow_update_sec", 0.12)))
        if now - self.last_emit < update_sec:
            return
        self.last_emit = now
        chosen = self.pick_live_targets(corpus_events)
        if chosen:
            self.spawn(chosen)

    def spawn(self, source_events):
        params = self.params_ref.snapshot()
        if not params["swarm_enabled"] or not source_events:
            return
        follow_strength = max(0.0, min(1.0, float(params.get("swarm_follow_strength", 0.85))))
        count = max(1, int(params["swarm_count"]))
        for idx in range(count):
            ev = source_events[idx % len(source_events)] if idx < len(source_events) else random.choice(source_events)
            audio = ev["audio"].copy()
            if len(audio) > 4 and random.random() < params["swarm_slice_probability"]:
                sr_guess = 48000
                min_len = int((40 / 1000.0) * sr_guess)
                max_len = int((260 / 1000.0) * sr_guess)
                max_len = min(max_len, len(audio))
                min_len = min(min_len, max_len)
                if max_len > 32:
                    target_len = random.randint(max(32, min_len), max(33, max_len))
                    start = random.randint(0, max(0, len(audio) - target_len))
                    audio = audio[start:start + target_len]
            if len(audio) > 4 and random.random() < params["swarm_reverse_probability"]:
                audio = audio[::-1].copy()
            delay = random.uniform(params["swarm_interval_min"], params["swarm_interval_max"]) * idx
            jitter = random.uniform(0.0, params["swarm_jitter_ms"] / 1000.0)
            gain = params["master_gain"] * params["swarm_gain"] * random.uniform(0.55, 1.2)
            gain *= (0.65 + 0.35 * follow_strength)
            threading.Thread(target=self._delayed_trigger, args=(audio, gain, delay + jitter, params["max_simultaneous_voices"]), daemon=True).start()

    def _delayed_trigger(self, audio, gain, delay, max_voices):
        time.sleep(max(0.0, delay))
        self.mixer.trigger(audio, gain, max_voices)


class TeammateEngine:
    def __init__(self, corpus, planner, mixer, memory, params_ref, midi_manager, swarm_reader, position_mapper=None, rave_transformer=None):
        self.corpus = corpus
        self.planner = planner
        self.mixer = mixer
        self.memory = memory
        self.params_ref = params_ref
        self.midi_manager = midi_manager
        self.swarm_reader = swarm_reader
        self.position_mapper = position_mapper
        self.rave_transformer = rave_transformer
        self.state = "LISTENING"
        self.state_deadline = 0.0
        self.pending_phrase = []
        self.strategy = "NONE"
        self._last_strategy = "NONE"
        self._consecutive_silences = 0
        self._last_play_time = 0.0
        self._input_silent_since = time.time()
        self._structure_bias  = {}
        self._structure_phase = ""
    def set_structure_bias(self, bias, phase=""):
        self._structure_bias  = bias
        self._structure_phase = phase
    def clear(self):
        self.pending_phrase = []
        self.state = "LISTENING"
        self.state_deadline = 0.0
        self.strategy = "NONE"
        self._last_strategy = "NONE"
        self._consecutive_silences = 0
        self._last_play_time = 0.0
        self._input_silent_since = time.time()
        self.mixer.clear()
        self.memory.clear()
    def update(self, features, intent):
        params = self.params_ref.snapshot()
        if not params["teammate_enabled"]:
            return
        now = time.time()
        # track when input goes quiet
        if features["rms"] > 0.01:
            self._input_silent_since = now
        corpus_size = len(self.corpus)
        if self.state == "LISTENING":
            if corpus_size >= 4:
                should_think = intent["end"] > 0.35 or (features["onset"] and random.random() < 0.18)
                if should_think and random.random() < params["reply_probability"]:
                    self.state = "THINKING"
                    self.state_deadline = now + random.uniform(params["min_reply_delay"], params["max_reply_delay"])
        elif self.state == "THINKING":
            if now >= self.state_deadline:
                input_silent_sec = now - self._input_silent_since
                context = {
                    "consecutive_silences": self._consecutive_silences,
                    "input_silent_sec": input_silent_sec,
                    "last_strategy": self._last_strategy,
                    "structure_bias": self._structure_bias,
                    "structure_phase": self._structure_phase,
                }
                self.strategy = self.planner.choose_strategy(features, intent, params, corpus_size, context)
                if self.strategy == "SILENCE":
                    self._consecutive_silences += 1
                    # duration scales with context
                    if self._last_strategy == "DENSIFICATION":
                        sil_dur = random.uniform(1.5, 4.0)
                    elif input_silent_sec > 2.0:
                        sil_dur = random.uniform(0.4, 1.2)  # you're quiet, we match briefly
                    else:
                        sil_dur = random.uniform(0.3, 1.8)
                    self.state = "RESTING"
                    self.state_deadline = now + sil_dur
                    self._last_strategy = "SILENCE"
                    return
                self._consecutive_silences = 0
                self._last_play_time = now
                self._last_strategy = self.strategy
                self.pending_phrase = self.planner.build_phrase(self.strategy, features, params, self.memory)
                if self.pending_phrase:
                    self._play_pending_phrase(params)
                self.state = "RESTING"
                self.state_deadline = now + random.uniform(0.12, 0.8)
        elif self.state == "RESTING":
            if now >= self.state_deadline:
                self.state = "LISTENING"
                self.strategy = "NONE"
    def _play_pending_phrase(self, params):
        swarm_source = []
        for ev in self.pending_phrase:
            audio = ev["audio"].copy()
            if len(audio) > 4 and random.random() < params["slice_probability"]:
                sr_guess = 48000
                min_len = int((80 / 1000.0) * sr_guess)
                max_len = int((420 / 1000.0) * sr_guess)
                max_len = min(max_len, len(audio))
                min_len = min(min_len, max_len)
                if max_len > 64:
                    target_len = random.randint(max(64, min_len), max(65, max_len))
                    start = random.randint(0, max(0, len(audio) - target_len))
                    audio = audio[start:start + target_len]
            if len(audio) > 4 and random.random() < params["reverse_probability"]:
                audio = audio[::-1].copy()
            # RAVE neural transform (optional)
            if (params.get("rave_enabled", False) and
                    self.rave_transformer is not None and
                    self.rave_transformer.loaded):
                try:
                    audio = self.rave_transformer.transform(audio, 48000)
                except Exception:
                    pass
            gain = params["master_gain"] * (0.35 + min(1.0, ev["rms"] * 8.0) * 0.65)
            if params["audio_enabled"]:
                self.mixer.trigger(audio, gain, params["max_simultaneous_voices"])
            if (params["midi_enabled"] or params.get("midi_note_out_enabled", False)) and self.midi_manager.port is not None:
                out_note = self.position_mapper.map_event_to_output_note(ev, self.corpus.events) if self.position_mapper is not None else ev.get("midi_note")
                if out_note is not None:
                    vel = int(max(1, min(127, ev["rms"] * 127.0 * params["midi_velocity_scale"])))
                    self.midi_manager.note(out_note, vel, params["midi_note_length"])
            self.memory.note_played(ev.get("id"))
            swarm_source.append(ev)
            time.sleep(max(0.02, (1.0 - params["density"]) * 0.18))
        if params["swarm_enabled"]:
            self.swarm_reader.spawn(swarm_source if params["swarm_follow_calltrans"] else list(self.corpus.events))
        self.pending_phrase = []


def global_clear(corpus, teammate, mixer=None, memory=None):
    corpus.clear()
    teammate.clear()
    if mixer is not None:
        try:
            mixer.clear()
        except Exception:
            pass
    if memory is not None:
        try:
            memory.clear()
        except Exception:
            pass
    print('>>> CORPUS CLEARED <<<')

def handle_global_menu_command(choice, params_ref, corpus, teammate, midi_manager, state, audio_engine=None):
    choice = choice.strip()

    if choice in {'/clear', '0', 'c'}:
        global_clear(corpus, teammate)
        return True

    if choice == '/list-audio':
        print_audio_devices()
        return True

    if choice.startswith('/audio-in '):
        if audio_engine is None:
            print('audio engine not available')
        else:
            try:
                idx = int(choice.split()[1])
                audio_engine.set_devices(input_device=idx)
                state['audio_in'] = idx
                print(f'audio input set to device {idx}')
            except Exception as e:
                print(f'audio-in error: {e}')
        return True

    if choice.startswith('/audio-out '):
        if audio_engine is None:
            print('audio engine not available')
        else:
            try:
                idx = int(choice.split()[1])
                audio_engine.set_devices(output_device=idx)
                state['audio_out'] = idx
                print(f'audio output set to device {idx}')
            except Exception as e:
                print(f'audio-out error: {e}')
        return True

    if choice == '/list-midi':
        print_midi_outputs()
        return True

    if choice == '/list-midi-in':
        print_midi_inputs()
        return True

    if choice.startswith('/midi-open '):
        try:
            idx = int(choice.split()[1])
            name = midi_manager.open_index(idx)
            params_ref.set('midi_enabled', True)
            params_ref.set('midi_output_index', idx)
            print(f'midi opened: {name}')
        except Exception as e:
            print(f'midi error: {e}')
        return True

    if choice.startswith('/midi-in-open '):
        try:
            idx = int(choice.split()[1])
            name = midi_manager.open_input_index(idx)
            params_ref.set('midi_note_in_enabled', True)
            params_ref.set('midi_note_in_port_index', idx)
            print(f'midi input opened: {name}')
        except Exception as e:
            print(f'midi input error: {e}')
        return True

    if choice == '/midi-in-close':
        midi_manager.close_input()
        params_ref.set('midi_note_in_enabled', False)
        params_ref.set('midi_note_in_port_index', -1)
        print('midi input closed')
        return True

    if choice == '/midi-close':
        midi_manager.close()
        params_ref.set('midi_enabled', False)
        params_ref.set('midi_output_index', -1)
        print('midi closed')
        return True

    if choice == '/status':
        merged = {**state, **params_ref.snapshot()}
        print('\n[STATUS]')
        for k, v in merged.items():
            print(f'{k:>24}: {v}')
        print()
        return True

    if choice == '/help':
        print_help()
        return True

    return False


def handle_numeric_shortcuts(choice, params_ref, corpus, teammate):
    choice = choice.strip()
    if choice == '0':
        global_clear(corpus, teammate)
        return True
    if choice in {'c', '/clear'}:
        global_clear(corpus, teammate)
        return True
    if choice == 'r':
        randomize_feel(params_ref)
        return True
    return False


def run_ascii_menu(params_ref, corpus, teammate, midi_manager, state, audio_engine=None, command_handler=None, poto_midi_manager=None):
    while True:
        clear_screen()
        print_banner()
        snap = params_ref.snapshot()
        print("PARAM MATRIX  |  numero = editer  |  toute commande /cmd fonctionne ici  |  q = quitter")
        print("-" * 86)
        for i, (key, typ) in enumerate(MENU_FIELDS, start=1):
            print(f"{i:>2}. {key:<30} = {snap.get(key)}  [{format_param_range(key)}]")
        print("-" * 86)
        try:
            _devs = mido.get_output_names() if mido else []
        except Exception:
            _devs = []
        _cur = poto_midi_manager.port_name if poto_midi_manager and poto_midi_manager.port_name else "none"
        _en  = "ON" if snap.get("poto_midi_enabled") else "OFF"
        print(f"  POtO MIDI │ device={_cur}  {_en}  ch={snap.get(chr(39)+'poto_midi_channel'+chr(39),1)}")
        print(f"  cmds: /poto-midi-device [N]  /poto-midi-on  /poto-midi-off  /poto-midi-channel N  /poto-midi-status")
        if _devs:
            print("  " + "  ".join(f"[{i}] {n}" for i, n in enumerate(_devs))[:82])
        _poto_grains = state.get("poto_grains", 0)
        _poto_rec  = "ON" if snap.get("poto_rec_enabled") else "OFF"
        _poto_perf = "ON" if snap.get("poto_enabled") else "OFF"
        print("-" * 86)
        print(f"  POtO      │ grains={_poto_grains}  rec={_poto_rec}  perf={_poto_perf}"
              f"  voices={snap.get('poto_voices',3)}  gain={snap.get('poto_gain',0.7)}  grain_ms={snap.get('poto_grain_ms',80)}")
        print(f"  cmds: o=rec  p=perf  l=clear  /poto-input mic|teammate|both  /poto-voices N  /poto-gain N  /poto-grain-ms N")
        print("  POtO MIDI │ device={_cur}  {_en}  ch={ch}  │  /poto-midi-on  /poto-midi-off  /poto-midi-channel N".format(
              _cur=_cur, _en=_en, ch=snap.get('poto_midi_channel', 1)))
        _midi_out  = state.get("midi_out") or "none"
        _midi_in   = state.get("midi_in")  or "none"
        _midi_ch   = snap.get("midi_channel", 0) + 1
        _midi_en   = "ON" if snap.get("midi_enabled") else "OFF"
        print("-" * 86)
        print(f"  MIDI      │ out={_midi_out}  in={_midi_in}  ch={_midi_ch}  {_midi_en}")
        print(f"  cmds: /list-midi  /midi-open N  /midi-close  /midi-channel N  /list-midi-in  /midi-in-open N")
        print("-" * 86)
        print("  RAVE      │ /rave-models  /rave-load N  /rave-on  /rave-off  /rave-status")
        print("  REC       │ /rec-start [nom]  /rec-stop  /rec-status  /rec-dir [chemin]")
        print("  INTEL     │ /structure-status  /style-status  /style-apply  /style-save  /style-reset")
        print("  SAVE      │ /save [nom]  /load [nom]  /saves  /profile ambient|acoustique|rythmique")
        print("-" * 86)
        choice = input("MENU> ").strip()

        if not choice:
            continue

        if choice.lower() in {"q", "quit", "exit", "/quit"}:
            clear_screen()
            return

        # Any /command or single-letter shortcut → forward to main command handler
        if choice.startswith("/") or choice in {"0", "c", "r", "o", "p", "l", "m"}:
            if command_handler is not None:
                command_handler(choice)
            else:
                handle_numeric_shortcuts(choice, params_ref, corpus, teammate)
                handle_global_menu_command(choice, params_ref, corpus, teammate, midi_manager, state, audio_engine)
            input("  [Entrée pour continuer]")
            continue

        # Numeric parameter edit
        if not choice.isdigit():
            print(f"  inconnu — tape un numero ou une commande /cmd")
            continue

        idx = int(choice) - 1
        if idx < 0 or idx >= len(MENU_FIELDS):
            print("  hors limites")
            continue

        key, typ = MENU_FIELDS[idx]
        current = snap.get(key)
        new_val = input(f"  {key} [{current}] [{format_param_range(key)}] > ").strip()

        if new_val == "":
            continue

        try:
            value = cast_menu_value(key, typ, new_val)
            params_ref.set(key, value)
            if key in {"xy_x", "xy_y"}:
                apply_xy_mapping(params_ref)
            print(f"  {key} = {params_ref.snapshot().get(key)}")
        except Exception as e:
            print(f"  invalide: {e}")

def run_engine(args):
    iq = queue.Queue(maxsize=128)
    oq = queue.Queue(maxsize=128)
    params = ParamsRef()
    analyzer = AudioAnalyzer()
    intent_analyzer = IntentAnalyzer()
    learning = LearningModel()
    segmenter = Segmenter(args.sample_rate)
    corpus = EphemeralCorpus()
    memory = RecentMemory()
    mixer = OutputMixer(args.block_size)
    midi_manager = MidiManager(params)
    position_mapper = PositionMapper(params, midi_manager)

    # AI layers (graceful fallback — all optional)
    aubio_analyzer   = AubioAnalyzer(args.sample_rate, args.block_size)
    librosa_extractor = LibrosaExtractor()
    rave_transformer = RAVETransformer()

    planner = PhrasePlanner(corpus, position_mapper)
    swarm_reader = SwarmReader(mixer, params)
    teammate = TeammateEngine(corpus, planner, mixer, memory, params, midi_manager, swarm_reader, position_mapper, rave_transformer)
    xy_controller = XYLiveController(params)
    audio = AudioEngine(iq, oq, args.sample_rate, args.block_size, args.audio_in, args.audio_out, params_ref=params)
    grain_cloud   = GrainCloud()
    grain_sampler    = GrainSampler(args.sample_rate, grain_cloud, analyzer)
    playback_sampler = GrainSampler(args.sample_rate, grain_cloud, analyzer)
    playback_sampler.recording = True  # always active when poto_capture_playback is on

    state = {
        "audio_in": args.audio_in, "audio_out": args.audio_out,
        "sample_rate": args.sample_rate, "block_size": args.block_size,
        "corpus": 0, "avg_rms": 0.0, "avg_freq": 0.0,
        "last_note": None, "machine_state": "LISTENING", "strategy": "NONE",
        "capture_to_corpus": True, "midi_out": None, "midi_in": None,
        "swarm_enabled": False, "poto_grains": 0,
        "aubio_bpm": 0.0, "aubio_freq": 0.0,
        "librosa_events": 0,
    }
    running = True
    event_ids = itertools.count(1)

    # visual engine shared state
    vis_state = {
        "strategy": "NONE", "machine_state": "LISTENING",
        "corpus": 0, "avg_rms": 0.0, "avg_rms_out": 0.0, "avg_freq": 0.0,
        "poto_grains": 0, "swarm_enabled": False, "onset": False,
        "waveform": [], "rendered_waveform": [],
        "grains_snap": [], "event_log": [], "params_snap": {},
    }
    visual_engine = VisualEngine(vis_state, grain_cloud)

    poto_midi_manager = MidiManager()   # separate MIDI port for POtO (optional)
    session_recorder = SessionRecorder(args.sample_rate)
    poto_engine = POtOEngine(grain_cloud, mixer, params, poto_midi_manager, midi_fallback=midi_manager)

    structure_analyzer = StructureAnalyzer()
    _saves_dir_base = os.path.dirname(os.path.abspath(sys.executable if getattr(sys, "frozen", False) else __file__))
    _profile_path = os.path.join(_saves_dir_base, "saves", "style_profile.json")
    style_profiler = StyleProfiler(_profile_path)

    # ── Pipe output (stdout JSON for teammate_neural.py) ──────────────────────
    _PIPE = not sys.stdout.isatty()
    _pipe_out = sys.__stdout__
    if _PIPE:
        sys.stdout = sys.stderr
    _STRAT_IDX = {"IMITATION":0,"CONTRASTE":1,"DENSIFICATION":2,"SPARSE":3,"SILENCE":4}
    _STATE_IDX  = {"LISTENING":0,"THINKING":1,"RESTING":2}
    _pipe_last  = 0.0
    _PIPE_DT    = 1.0 / 30.0

    def analysis_loop():
        nonlocal running, _pipe_last
        librosa_enriched = 0
        while running:
            try:
                block = iq.get(timeout=0.1)
            except queue.Empty:
                continue
            now_time = time.time()
            snap = params.snapshot()

            features = analyzer.analyze(block, args.sample_rate)
            intent = intent_analyzer.update(features)
            learning.update_features(features)
            swarm_reader.update_target(features)
            structure_analyzer.update(features)
            teammate.set_structure_bias(structure_analyzer.get_bias(), structure_analyzer.phase)

            # Aubio per-block analysis
            if snap.get("aubio_enabled", False) and aubio_analyzer._ready:
                try:
                    ab = aubio_analyzer.analyze(block)
                    # Override freq/onset with aubio if confidence is high
                    if ab["confidence"] > 0.5 and ab["freq"] > 40:
                        features["freq"] = ab["freq"]
                    if ab["onset"]:
                        features["onset"] = True
                    state["aubio_bpm"]  = ab["bpm"]
                    state["aubio_freq"] = ab["freq"]
                except Exception:
                    pass

            segs = segmenter.process_block(block, now_time)
            for seg_time, seg_audio in segs:
                seg_feat = analyzer.analyze(seg_audio, args.sample_rate)
                if snap.get("compress_mode") == "ambient":
                    seg_rms = float(np.sqrt(np.mean(seg_audio.astype(np.float64) ** 2) + 1e-12))
                    if seg_rms > 1e-6:
                        seg_audio = (seg_audio * min(3.0, 0.16 / seg_rms)).astype(np.float32)
                event = {
                    "id": next(event_ids),
                    "audio": seg_audio,
                    "rms": seg_feat["rms"],
                    "freq": seg_feat["freq"],
                    "centroid": seg_feat["centroid"],
                    "onset": seg_feat["onset"],
                    "note": seg_feat["note"],
                    "midi_note": seg_feat["midi_note"],
                    "duration_ms": seg_feat["duration_ms"],
                    "time": seg_time,
                }
                capture_enabled = snap["input_to_corpus_enabled"]
                if capture_enabled:
                    corpus.add(event)
                    memory.note_heard(event["id"])
                    style_profiler.observe_event(event)
                    # Submit to librosa background extractor
                    if snap.get("librosa_enabled", False):
                        n_mfcc = int(snap.get("librosa_mfcc_n", 13))
                        librosa_extractor.submit(event, args.sample_rate, n_mfcc)
                        librosa_enriched += 1
                state["last_note"] = event["note"]
                state["capture_to_corpus"] = capture_enabled

            teammate.update(features, intent)
            grain_sampler.process_block(block, snap.get("poto_grain_ms", 80))
            poto_engine.process(features)
            state["corpus"]        = len(corpus)
            state["avg_rms"]       = round(learning.avg_rms, 4)
            state["avg_freq"]      = round(learning.avg_freq, 2)
            state["machine_state"] = teammate.state
            state["strategy"]      = teammate.strategy
            params.set("teammate_strategy", teammate.strategy)
            state["swarm_enabled"] = snap["swarm_enabled"]
            state["poto_grains"]   = len(grain_cloud)
            state["midi_out"]      = midi_manager.port_name
            state["midi_in"]       = midi_manager.input_port_name
            state["librosa_events"] = librosa_enriched
            # ── pipe JSON to teammate_neural.py ──────────────────────────────
            if _PIPE:
                _now = time.time()
                if _now - _pipe_last >= _PIPE_DT:
                    _pipe_last = _now
                    snap_ = params.snapshot()
                    try:
                        import json as _json
                        _pipe_out.write(_json.dumps({
                            "rms_in":  state["avg_rms"],
                            "rms_out": round(float(vis_state.get("avg_rms_out", 0.0)), 5),
                            "freq":    state["avg_freq"],
                            "strat":   _STRAT_IDX.get(state["strategy"], 0),
                            "state":   _STATE_IDX.get(state["machine_state"], 0),
                            "corpus":  state["corpus"],
                            "grains":  state["poto_grains"],
                            "density": round(float(snap_.get("density", 0.5)), 3),
                            "onset":   bool(state.get("onset", False)),
                        }) + "\n")
                        _pipe_out.flush()
                    except Exception:
                        pass
            # feed visual engine
            if visual_engine.running:
                ds = max(1, len(block) // 256)
                vis_state["waveform"]       = block[::ds].tolist()
                vis_state["corpus"]         = state["corpus"]
                vis_state["avg_rms"]        = state["avg_rms"]
                vis_state["avg_freq"]       = state["avg_freq"]
                vis_state["machine_state"]  = state["machine_state"]
                vis_state["strategy"]       = state["strategy"]
                vis_state["swarm_enabled"]  = state["swarm_enabled"]
                vis_state["poto_grains"]    = state["poto_grains"]
                vis_state["onset"]          = state.get("onset", False)
                vis_state["params_snap"]    = snap
                vis_state["last_weights"]   = dict(planner.last_weights)
                vis_state["last_factors"]   = dict(planner.last_factors)

    def output_loop():
        nonlocal running
        while running:
            try:
                snap = params.snapshot()
                rendered = mixer.render_block(snap.get("compress_mode", "off"))
                oq.put(rendered, timeout=0.1)
                session_recorder.process_block(rendered)
                # Mono mix for analysis/POtO (rendered is stereo (N,2))
                rendered_mono = rendered[:, 0] * 0.5 + rendered[:, 1] * 0.5
                # Feed playback into POtO grain cloud when enabled
                if snap.get("poto_capture_playback", False):
                    playback_sampler.process_block(rendered_mono, snap.get("poto_grain_ms", 80))
                # Use TEAMMATE output as POtO analysis input (teammate or both mode)
                if snap.get("poto_input_mode", "mic") in ("teammate", "both") and snap.get("poto_enabled", False):
                    tm_features = analyzer.analyze(rendered_mono, args.sample_rate)
                    poto_engine.process_teammate(tm_features)
                # feed rendered waveform + grain snapshot to visual engine
                if visual_engine.running:
                    ds = max(1, len(rendered_mono) // 256)
                    vis_state["rendered_waveform"] = rendered_mono[::ds].tolist()
                    vis_state["avg_rms_out"] = float(np.sqrt(np.mean(rendered_mono ** 2) + 1e-12))
                    # refresh grain cloud snapshot every ~0.5s (every ~20 blocks)
                    if not hasattr(output_loop, "_grain_tick"):
                        output_loop._grain_tick = 0
                    output_loop._grain_tick += 1
                    if output_loop._grain_tick % 20 == 0:
                        with grain_cloud.lock:
                            vis_state["grains_snap"] = [
                                {"freq": g.get("freq", 0.0), "centroid": g.get("centroid", 0.0), "amp": g.get("amp", 0.0)}
                                for g in list(grain_cloud.grains)
                            ]
            except queue.Full:
                pass

    threading.Thread(target=analysis_loop, daemon=True).start()
    threading.Thread(target=output_loop, daemon=True).start()
    log.info("TEAMMATE_PC starting")
    try:
        audio.start()
        log.info(f"audio stream started — in={args.audio_in} out={args.audio_out} sr={args.sample_rate}")
    except Exception as e:
        log.critical(f"audio stream failed to start: {e}\n{traceback.format_exc()}")
        print(f"AUDIO ERROR: {e}\nCheck TEAMMATE.log for details.")
        return

    startup_animation()
    print_welcome()
    device_setup(audio, midi_manager, params)

    def handle_cmd(cmd):
        """Process a single command string. Returns True if /quit was requested."""
        cmd = cmd.strip()
        if not cmd:
            return False
        if cmd == "/help":
            print_help(); return False
        if cmd in {"r", "/random"}:
            randomize_feel(params); return False
        # POtO shortcuts
        if cmd in {"o", "/poto-rec-on", "/poto-rec-off"}:
            if params.snapshot().get("poto_rec_enabled", False) or cmd == "/poto-rec-off":
                grain_sampler.stop(); params.set("poto_rec_enabled", False)
                print(f"POtO rec OFF -- {len(grain_cloud)} grains stored")
            else:
                grain_sampler.start(); params.set("poto_rec_enabled", True)
                print(f"POtO rec ON  -- cloud: {len(grain_cloud)} grains")
            return False
        if cmd in {"p", "/poto-on", "/poto-off"}:
            if params.snapshot().get("poto_enabled", False) or cmd == "/poto-off":
                params.set("poto_enabled", False); print("POtO performance OFF")
            else:
                params.set("poto_enabled", True); print(f"POtO performance ON  -- {len(grain_cloud)} grains ready")
            return False
        if cmd in {"l", "/poto-clear"}:
            grain_cloud.clear(); print("POtO grain cloud cleared"); return False
        if cmd in {"m", "/poto-status"}:
            snap = params.snapshot()
            _inp = snap.get('poto_input_mode', 'mic')
            print(f"  POtO grains={len(grain_cloud)}"
                  f"  rec={'ON' if snap['poto_rec_enabled'] else 'OFF'}"
                  f"  perf={'ON' if snap['poto_enabled'] else 'OFF'}"
                  f"  input={_inp}"
                  f"  playback_capture={'ON' if snap['poto_capture_playback'] else 'OFF'}"
                  f"  voices={snap['poto_voices']}  gain={snap['poto_gain']}"
                  f"  grain_ms={snap['poto_grain_ms']}")
            return False
        if cmd == "/poto-capture-playback-on":
            params.set("poto_capture_playback", True)
            print("  POtO playback capture ON"); return False
        if cmd == "/poto-capture-playback-off":
            params.set("poto_capture_playback", False)
            print("  POtO playback capture OFF"); return False
        if cmd.startswith("/poto-input "):
            mode = cmd.split()[1].strip().lower()
            if mode in ("mic", "teammate", "both"):
                params.set("poto_input_mode", mode)
                labels = {"mic": "micro seulement", "teammate": "TEAMMATE seulement", "both": "micro + TEAMMATE"}
                print(f"  POtO input = {labels[mode]}")
            else:
                print("  modes: mic | teammate | both")
            return False
        # POtO MIDI out
        if cmd == "/poto-midi-on":
            if poto_midi_manager.port is None:
                print("  no MIDI device open for POtO — use /poto-midi-device N")
            else:
                params.set("poto_midi_enabled", True)
                snap = params.snapshot()
                print(f"  POtO MIDI ON  device={poto_midi_manager.port_name}  ch={snap['poto_midi_channel']}")
            return False
        if cmd == "/poto-midi-off":
            params.set("poto_midi_enabled", False); print("  POtO MIDI OFF"); return False
        if cmd.startswith("/poto-midi-channel "):
            try:
                ch = max(1, min(16, int(cmd.split()[1])))
                params.set("poto_midi_channel", ch)
                print(f"  POtO MIDI channel → {ch}")
            except Exception:
                print("  usage: /poto-midi-channel 1..16")
            return False
        if cmd.startswith("/poto-midi-note-length "):
            try:
                l = float(cmd.split()[1])
                params.set("poto_midi_note_length", l)
                print(f"  POtO MIDI note length → {l}s")
            except Exception:
                print("  usage: /poto-midi-note-length 0.01..4.0")
            return False
        if cmd == "/poto-midi-device" or cmd.startswith("/poto-midi-device "):
            parts = cmd.split()
            if len(parts) == 1:
                try:
                    names = mido.get_output_names() if mido else []
                    if names:
                        print("  MIDI output devices:")
                        for i, n in enumerate(names):
                            mark = " ◄" if n == poto_midi_manager.port_name else ""
                            print(f"    [{i}]  {n}{mark}")
                        print("  → /poto-midi-device N  to open")
                    else:
                        print("  no MIDI output devices found")
                except Exception as e:
                    print(f"  error: {e}")
            else:
                try:
                    idx = int(parts[1])
                    name = poto_midi_manager.open_index(idx)
                    params.set("poto_midi_device_index", idx)
                    params.set("poto_midi_enabled", True)
                    print(f"  POtO MIDI → {name}  (ON)")
                except Exception as e:
                    print(f"  error: {e}")
            return False
        if cmd == "/poto-midi-status":
            snap = params.snapshot()
            dev  = poto_midi_manager.port_name or "none"
            print(f"  POtO MIDI  enabled={snap['poto_midi_enabled']}"
                  f"  device={dev}"
                  f"  ch={snap['poto_midi_channel']}"
                  f"  note_length={snap['poto_midi_note_length']}")
            return False
        # AI layers
        if cmd == "/aubio-on":
            if not _AUBIO: print("  aubio not installed — pip install aubio")
            elif not aubio_analyzer._ready: print("  aubio init failed — check log")
            else: params.set("aubio_enabled", True); print("  aubio ON  (pitch/onset/BPM)")
            return False
        if cmd == "/aubio-off":
            params.set("aubio_enabled", False); print("  aubio OFF"); return False
        if cmd == "/show-bpm-on":
            params.set("show_bpm", True); print("  BPM display ON"); return False
        if cmd == "/show-bpm-off":
            params.set("show_bpm", False); print("  BPM display OFF"); return False
        if cmd == "/librosa-on":
            if not _LIBROSA: print("  librosa not installed — pip install librosa")
            else: params.set("librosa_enabled", True); print("  librosa ON")
            return False
        if cmd == "/librosa-off":
            params.set("librosa_enabled", False); print("  librosa OFF"); return False
        if cmd.startswith("/librosa-mfcc-weight "):
            try:
                params.set("librosa_mfcc_weight", float(cmd.split()[1]))
                print(f"  librosa_mfcc_weight = {params.snapshot()['librosa_mfcc_weight']}")
            except Exception as e: print(f"  bad value: {e}")
            return False
        if cmd == "/rave-on":
            if not _TORCH: print("  torch not installed — pip install torch")
            elif not rave_transformer.loaded: print("  RAVE model not loaded — use /rave-model <path> or /rave-browse")
            else: params.set("rave_enabled", True); print(f"  RAVE ON  model={rave_transformer._model_path}")
            return False
        if cmd == "/rave-off":
            params.set("rave_enabled", False); print("  RAVE OFF"); return False
        if cmd.startswith("/rave-model "):
            path = cmd[len("/rave-model "):].strip()
            try: rave_transformer.load(path); print(f"  RAVE model loaded: {path}")
            except Exception as e: print(f"  RAVE load error: {e}")
            return False
        if cmd == "/rave-models":
            import os, glob as _glob
            _base = os.path.dirname(os.path.abspath(sys.executable if getattr(sys, "frozen", False) else __file__))
            _rave_dir = os.path.join(_base, "rave_models")
            os.makedirs(_rave_dir, exist_ok=True)
            _files = sorted(_glob.glob(os.path.join(_rave_dir, "*.ts")))
            if not _files:
                print(f"  no models found in {_rave_dir}")
                print("  place .ts files there and retry")
            else:
                print(f"  RAVE models in {_rave_dir}:")
                for _i, _f in enumerate(_files):
                    _marker = "  *" if rave_transformer._model_path == _f else "   "
                    print(f"{_marker} [{_i}] {os.path.basename(_f)}")
                print("  load with: /rave-load 0")
            return False
        if cmd.startswith("/rave-load "):
            import os, glob as _glob
            _base = os.path.dirname(os.path.abspath(sys.executable if getattr(sys, "frozen", False) else __file__))
            _rave_dir = os.path.join(_base, "rave_models")
            _files = sorted(_glob.glob(os.path.join(_rave_dir, "*.ts")))
            try:
                _idx = int(cmd.split()[1])
                _path = _files[_idx]
                rave_transformer.load(_path)
                print(f"  RAVE model loaded: {os.path.basename(_path)}")
            except (IndexError, ValueError):
                print(f"  invalid index — use /rave-models to list")
            except Exception as e:
                print(f"  RAVE load error: {e}")
            return False
        if cmd == "/rave-browse":
            import os
            try:
                import tkinter as _tk
                from tkinter import filedialog as _fd
                _root = _tk.Tk(); _root.withdraw(); _root.attributes("-topmost", True)
                _base = os.path.dirname(os.path.abspath(sys.executable if getattr(sys, "frozen", False) else __file__))
                _rave_dir = os.path.join(_base, "rave_models")
                os.makedirs(_rave_dir, exist_ok=True)
                _path = _fd.askopenfilename(
                    title="Select RAVE model",
                    initialdir=_rave_dir,
                    filetypes=[("RAVE TorchScript", "*.ts"), ("All files", "*.*")]
                )
                _root.destroy()
                if _path:
                    rave_transformer.load(_path)
                    print(f"  RAVE model loaded: {os.path.basename(_path)}")
                else:
                    print("  cancelled")
            except Exception as e:
                print(f"  /rave-browse error: {e}")
            return False
        if cmd == "/rave-status":
            print(f"  RAVE loaded={rave_transformer.loaded}  enabled={params.snapshot().get('rave_enabled')}  model={rave_transformer._model_path or 'none'}")
            return False
        # ── Session recording ────────────────────────────────────────────────
        if cmd.startswith("/rec-start") or cmd == "/rec-start":
            import os, time as _t
            parts    = cmd.split(None, 1)
            name     = parts[1].strip() if len(parts) > 1 else "session"
            name     = name.replace(" ", "_")
            rec_dir  = params.snapshot().get("rec_dir", os.path.expanduser("~/TEAMMATE_recordings"))
            stamp    = _t.strftime("%Y-%m-%d_%H-%M-%S")
            filepath = os.path.join(rec_dir, f"{name}_{stamp}.wav")
            if session_recorder.recording:
                print("  recording already in progress — /rec-stop first")
            else:
                session_recorder.start(filepath)
                print(f"  REC START → {filepath}")
            return False
        if cmd == "/rec-stop":
            if not session_recorder.recording:
                print("  no recording in progress")
            else:
                elapsed, filepath = session_recorder.stop()
                m, s = divmod(int(elapsed), 60)
                print(f"  REC STOP  — saving {m:02d}:{s:02d} → {filepath}")
            return False
        if cmd == "/rec-status":
            if session_recorder.recording:
                m, s = divmod(int(session_recorder.elapsed), 60)
                print(f"  REC  ON   {m:02d}:{s:02d}  ~{session_recorder.size_mb:.1f} MB")
                print(f"  file → {session_recorder.filename}")
            else:
                import os
                rec_dir = params.snapshot().get("rec_dir", os.path.expanduser("~/TEAMMATE_recordings"))
                print(f"  REC  OFF  dir={rec_dir}")
            return False
        if cmd.startswith("/rec-dir "):
            import os
            new_dir = cmd[len("/rec-dir "):].strip()
            params.set("rec_dir", new_dir)
            print(f"  rec_dir → {new_dir}")
            return False
        if cmd == "/lib-status":
            print(f"""
  AI LIBRARY STATUS
  aubio    installed={_AUBIO}   ready={aubio_analyzer._ready}   enabled={params.snapshot().get('aubio_enabled')}
             bpm={state.get('aubio_bpm', 0.0):.1f}  freq={state.get('aubio_freq', 0.0):.1f} Hz
  librosa  installed={_LIBROSA}   enabled={params.snapshot().get('librosa_enabled')}
             events={state.get('librosa_events', 0)}  mfcc_weight={params.snapshot().get('librosa_mfcc_weight')}
  torch    installed={_TORCH}
  RAVE     loaded={rave_transformer.loaded}   enabled={params.snapshot().get('rave_enabled')}
             model={rave_transformer._model_path or 'none'}
""")
            return False
        # Corpus / clear
        if cmd in {"0", "c", "/clear"}:
            corpus.clear(); teammate.clear(); print("corpus cleared"); return False
        if cmd == "/status":
            merged = {**state, **params.snapshot()}
            print("\n[STATUS]")
            for k, v in merged.items(): print(f"{k:>28}: {v}")
            print()
            return False
        if cmd == "/list-audio":
            print_audio_devices(); return False
        if cmd.startswith("/audio-in "):
            try:
                idx = int(cmd.split()[1]); audio.set_devices(input_device=idx)
                state["audio_in"] = idx; print(f"audio input set to device {idx}")
            except Exception as e: print(f"audio-in error: {e}")
            return False
        if cmd.startswith("/audio-out "):
            try:
                idx = int(cmd.split()[1]); audio.set_devices(output_device=idx)
                state["audio_out"] = idx; print(f"audio output set to device {idx}")
            except Exception as e: print(f"audio-out error: {e}")
            return False
        if cmd == "/list-midi": print_midi_outputs(); return False
        if cmd == "/list-midi-in": print_midi_inputs(); return False
        if cmd == "/menu":
            run_ascii_menu(params, corpus, teammate, midi_manager, state, audio, command_handler=handle_cmd, poto_midi_manager=poto_midi_manager)
            print_banner(); print("RETURNED FROM MENU // SYSTEM STILL RUNNING\n")
            return False
        if cmd.startswith("/midi-open "):
            try:
                idx = int(cmd.split()[1]); name = midi_manager.open_index(idx)
                params.set("midi_enabled", True); params.set("midi_output_index", idx)
                print(f"midi opened: {name}")
            except Exception as e: print(f"midi error: {e}")
            return False
        if cmd.startswith("/midi-in-open "):
            try:
                idx = int(cmd.split()[1]); name = midi_manager.open_input_index(idx)
                params.set("midi_note_in_enabled", True); params.set("midi_note_in_port_index", idx)
                print(f"midi input opened: {name}")
            except Exception as e: print(f"midi input error: {e}")
            return False
        if cmd == "/midi-in-close":
            midi_manager.close_input(); params.set("midi_note_in_enabled", False)
            params.set("midi_note_in_port_index", -1); print("midi input closed"); return False
        if cmd == "/midi-close":
            midi_manager.close(); params.set("midi_enabled", False)
            params.set("midi_output_index", -1); print("midi closed"); return False
        if cmd.startswith("/midi-channel "):
            try:
                user_ch = int(cmd.split()[1])
                if user_ch < 1 or user_ch > 16: raise ValueError("channel must be 1-16")
                params.set("midi_channel", user_ch - 1); print(f"midi_channel = {user_ch}")
            except Exception as e: print(f"bad value: {e}")
            return False
        if cmd == "/vis-on":
            try:
                visual_engine.start()
                print("  visual engine ON")
            except Exception as e:
                print(f"  visual error: {e}")
            return False
        if cmd == "/vis-off":
            visual_engine.stop()
            print("  visual engine OFF")
            return False
        simple = {
            "/audio-on": ("audio_enabled", True), "/audio-off": ("audio_enabled", False),
            "/ghost-on": ("ghost_mode", True), "/ghost-off": ("ghost_mode", False),
            "/monitor-input-on": ("input_monitor_enabled", True), "/monitor-input-off": ("input_monitor_enabled", False),
            "/teammate-on": ("teammate_enabled", True), "/teammate-off": ("teammate_enabled", False),
            "/capture-on": ("input_to_corpus_enabled", True), "/capture-off": ("input_to_corpus_enabled", False),
            "/calltrans-on": ("calltrans_enabled", True), "/calltrans-off": ("calltrans_enabled", False),
            "/calltrans-follow-input-on": ("calltrans_follow_input_only", True), "/calltrans-follow-input-off": ("calltrans_follow_input_only", False),
            "/swarm-on": ("swarm_enabled", True), "/swarm-off": ("swarm_enabled", False),
            "/swarm-follow-calltrans-on": ("swarm_follow_calltrans", True), "/swarm-follow-calltrans-off": ("swarm_follow_calltrans", False),
            "/swarm-follow-live-on": ("swarm_follow_live", True), "/swarm-follow-live-off": ("swarm_follow_live", False),
            "/midi-note-in-on": ("midi_note_in_enabled", True), "/midi-note-in-off": ("midi_note_in_enabled", False),
            "/midi-note-out-on": ("midi_note_out_enabled", True), "/midi-note-out-off": ("midi_note_out_enabled", False),
            "/xy-on": ("xy_enabled", True), "/xy-off": ("xy_enabled", False),
            "/xy-live": ("xy_mode", "live"), "/xy-hold": ("xy_mode", "hold"),
        }
        if cmd in simple:
            k, v = simple[cmd]; params.set(k, v)
            if cmd == "/ghost-on":
                print("GHOST MODE ON — ton playback muté, TEAMMATE reste audible"); return False
            elif cmd == "/ghost-off":
                print("GHOST MODE OFF — playback normal"); return False
            if cmd == "/xy-on":
                try: xy_controller.start()
                except Exception as e: print(f"xy error: {e}")
            elif cmd == "/xy-off": xy_controller.stop()
            elif k in {"xy_mode", "xy_enabled"}: apply_xy_mapping(params)
            print(f"{k} = {params.snapshot().get(k)}"); return False
        if cmd.startswith("/profile "):
            name = cmd.split()[1].strip().lower()
            print(f"profile applied: {name}" if apply_profile(params, name) else f"unknown profile: {name}"); return False
        if cmd.startswith("/self-sustain "):
            name = cmd.split()[1].strip().lower()
            print(f"self-sustain applied: {name}" if apply_self_sustain(params, name) else f"unknown: {name}"); return False
        if cmd.startswith("/compress "):
            mode = cmd.split()[1].strip().lower()
            if mode in {"off","gentle","hard","ambient"}: params.set("compress_mode", mode); print(f"compress_mode = {mode}")
            else: print("unknown compress mode")
            return False
        if cmd == "/xy-reset":
            params.set("xy_x", 0.5); params.set("xy_y", 0.5); apply_xy_mapping(params)
            print("xy reset to center"); return False
        if cmd == "/xy-print":
            snap = params.snapshot()
            print(f"xy = ({snap.get('xy_x')}, {snap.get('xy_y')}) enabled={snap.get('xy_enabled')} mode={snap.get('xy_mode')}"); return False
        if cmd.startswith("/xy-set "):
            try:
                _, x, y = cmd.split(); params.set("xy_x", float(x)); params.set("xy_y", float(y))
                apply_xy_mapping(params); print(f"xy = ({params.snapshot().get('xy_x')}, {params.snapshot().get('xy_y')})")
            except Exception as e: print(f"bad xy values: {e}")
            return False
        if cmd.startswith("/calltrans-preset "):
            preset = cmd.split()[1].strip().lower()
            print(f"preset applied: {preset}" if apply_preset(params, preset) else f"unknown preset: {preset}"); return False
        if cmd == "/saves":
            import os, glob as _glob
            saves_dir = os.path.join(os.path.dirname(os.path.abspath(sys.executable if getattr(sys, "frozen", False) else __file__)), "saves")
            files = sorted(_glob.glob(os.path.join(saves_dir, "*.json")))
            if not files:
                print("  no saves found")
            else:
                for f in files:
                    print(f"  {os.path.splitext(os.path.basename(f))[0]}")
            return False
        if cmd.startswith("/save"):
            import os, json as _json
            parts = cmd.split(None, 1)
            name = parts[1].strip() if len(parts) > 1 else "default"
            saves_dir = os.path.join(os.path.dirname(os.path.abspath(sys.executable if getattr(sys, "frozen", False) else __file__)), "saves")
            os.makedirs(saves_dir, exist_ok=True)
            path = os.path.join(saves_dir, f"{name}.json")
            try:
                params.save_to_file(path)
                print(f"  saved → {name}.json")
            except Exception as e:
                print(f"  save error: {e}")
            return False
        if cmd.startswith("/load"):
            import os
            parts = cmd.split(None, 1)
            name = parts[1].strip() if len(parts) > 1 else "default"
            saves_dir = os.path.join(os.path.dirname(os.path.abspath(sys.executable if getattr(sys, "frozen", False) else __file__)), "saves")
            path = os.path.join(saves_dir, f"{name}.json")
            try:
                params.load_from_file(path)
                print(f"  loaded ← {name}.json")
            except FileNotFoundError:
                print(f"  not found: {name}.json")
            except Exception as e:
                print(f"  load error: {e}")
            return False
        if cmd == "/structure-status":
            print(f"  STRUCTURE ANALYZER\n{structure_analyzer.status_str()}")
            return False
        if cmd == "/style-status":
            print(f"  STYLE PROFILER\n{style_profiler.status_str()}")
            return False
        if cmd == "/style-apply":
            sug = style_profiler.get_suggested_params()
            if sug:
                for _k, _v in sug.items():
                    params.set(_k, _v)
                print(f"  style applied: {sug}")
            else:
                print("  not enough sessions yet — play 2+ sessions first")
            return False
        if cmd == "/style-save":
            style_profiler.save_session()
            print("  style profile saved")
            return False
        if cmd == "/style-reset":
            import os as _os2
            try:
                _os2.remove(style_profiler.profile_path)
            except FileNotFoundError:
                pass
            except Exception as e:
                print(f"  reset error: {e}")
            style_profiler.cumulative = {"session_count": 0, "freq_hist": [0]*128,
                "avg_rms": 0.05, "avg_density": 10.0,
                "avg_silence_gap": 2.0, "avg_silence_bias": 0.3}
            style_profiler._freq       = [0] * 128
            style_profiler._rms_list   = []
            style_profiler._event_count = 0
            print("  style profile reset")
            return False
        if cmd == "/quit":
            style_profiler.save_session()
            return True
        numeric = {
            "/gain ": ("master_gain", float), "/monitor-input-gain ": ("input_monitor_gain", float),
            "/teammate-output-gain ": ("teammate_output_gain", float),
            "/reply-probability ": ("reply_probability", float),
            "/min-reply-delay ": ("min_reply_delay", float), "/max-reply-delay ": ("max_reply_delay", float),
            "/phrase-min-events ": ("phrase_min_events", int), "/phrase-max-events ": ("phrase_max_events", int),
            "/density ": ("density", float), "/contrast-amount ": ("contrast_amount", float),
            "/silence-bias ": ("silence_bias", float),
            "/max-simultaneous-voices ": ("max_simultaneous_voices", int),
            "/calltrans-amount ": ("calltrans_amount", float),
            "/calltrans-timbre-weight ": ("calltrans_timbre_weight", float),
            "/calltrans-pitch-weight ": ("calltrans_pitch_weight", float),
            "/calltrans-duration-weight ": ("calltrans_duration_weight", float),
            "/calltrans-energy-weight ": ("calltrans_energy_weight", float),
            "/swarm-count ": ("swarm_count", int), "/swarm-gain ": ("swarm_gain", float),
            "/swarm-interval-min ": ("swarm_interval_min", float), "/swarm-interval-max ": ("swarm_interval_max", float),
            "/swarm-slice-probability ": ("swarm_slice_probability", float),
            "/swarm-reverse-probability ": ("swarm_reverse_probability", float),
            "/swarm-jitter-ms ": ("swarm_jitter_ms", float),
            "/midi-velocity-scale ": ("midi_velocity_scale", float), "/midi-note-length ": ("midi_note_length", float),
            "/midi-note-min ": ("midi_note_in_min", int), "/midi-note-max ": ("midi_note_in_max", int),
            "/midi-out-note-min ": ("midi_note_out_min", int), "/midi-out-note-max ": ("midi_note_out_max", int),
            "/corpus-window-start ": ("corpus_window_start", float), "/corpus-window-end ": ("corpus_window_end", float),
            "/position-window-radius ": ("position_window_radius", int),
            "/poto-voices ": ("poto_voices", int), "/poto-gain ": ("poto_gain", float),
            "/poto-grain-ms ": ("poto_grain_ms", int), "/poto-trigger-interval ": ("poto_trigger_interval", float),
            "/poto-chord-spread ": ("poto_chord_spread", float),
            "/poto-pitch-weight ": ("poto_pitch_weight", float), "/poto-timbre-weight ": ("poto_timbre_weight", float),
            "/poto-amp-weight ": ("poto_amp_weight", float),
            "/swarm-follow-mode ": ("swarm_follow_mode", str), "/swarm-follow-strength ": ("swarm_follow_strength", float),
            "/swarm-follow-update-sec ": ("swarm_follow_update_sec", float),
            "/swarm-follow-top-k ": ("swarm_follow_top_k", int),
            "/aubio-pitch-tolerance ": ("aubio_pitch_tolerance", float),
            "/aubio-onset-threshold ": ("aubio_onset_threshold", float),
            "/librosa-mfcc-n ": ("librosa_mfcc_n", int),
        }
        for prefix, (key, cast) in numeric.items():
            if cmd.startswith(prefix):
                try:
                    value = cast(cmd.split(None, 1)[1].strip()); params.set(key, value)
                    if key == "aubio_pitch_tolerance": aubio_analyzer.set_tolerance(value)
                    elif key == "aubio_onset_threshold": aubio_analyzer.set_onset_threshold(value)
                    print(f"{key} = {params.snapshot().get(key)}")
                except Exception as e: print(f"bad value: {e}")
                return False
        print("unknown command // type /help")
        return False

    try:
        while running:
            try:
                snap = params.snapshot()
                bpm_hint = f" {state.get('aubio_bpm', 0.0):.0f}bpm" if snap.get("show_bpm") and snap.get("aubio_enabled") else ""
                poto_hint = (f"[POtO grains={len(grain_cloud)} rec={'ON' if snap.get('poto_rec_enabled') else 'off'} perf={'ON' if snap.get('poto_enabled') else 'off'}] "
                             if snap.get('poto_enabled') or snap.get('poto_rec_enabled') or len(grain_cloud) > 0 else "")
                cmd = input(f"TEAMMATE.POTO{bpm_hint} {poto_hint}> ").strip()
            except (EOFError, KeyboardInterrupt):
                break
            if not cmd:
                continue

            if handle_cmd(cmd):
                break
    finally:
        running = False
        audio.stop()
        midi_manager.close()
        midi_manager.close_input()
        xy_controller.stop()
        log.info("TEAMMATE_PC stopped")
        print(f"\nTEAMMATE stopped.  Log: {_log_path}\n")

def main():
    parser = argparse.ArgumentParser(description="TEAMMATE.POTO — aubio + librosa + RAVE")
    sub = parser.add_subparsers(dest="command")
    sub.add_parser("list-audio")
    sub.add_parser("list-midi")
    sub.add_parser("list-midi-in")
    run = sub.add_parser("run")
    run.add_argument("--audio-in", type=int, default=None)
    run.add_argument("--audio-out", type=int, default=None)
    run.add_argument("--sample-rate", type=int, default=DEFAULT_SAMPLE_RATE)
    run.add_argument("--block-size", type=int, default=DEFAULT_BLOCK_SIZE)
    args = parser.parse_args()
    if args.command == "list-audio":
        print_audio_devices()
    elif args.command == "list-midi":
        print_midi_outputs()
    elif args.command == "list-midi-in":
        print_midi_inputs()
    elif args.command == "run":
        run_engine(args)
    else:
        import types
        default_args = types.SimpleNamespace(
            audio_in=None,
            audio_out=None,
            sample_rate=DEFAULT_SAMPLE_RATE,
            block_size=DEFAULT_BLOCK_SIZE,
        )
        run_engine(default_args)

if __name__ == "__main__":
    main()
