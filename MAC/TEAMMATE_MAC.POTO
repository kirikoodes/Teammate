def device_setup(audio_engine, midi_manager, params):
    def pick(label, items):
        print(f"\n  {label}")
        print("  " + "\u2500" * 40)
        if not items:
            print("    none detected")
            return None
        for idx, name in items:
            print(f"    {idx:>3} | {name}")
        while True:
            raw = input("  > select number (Enter to skip): ").strip()
            if raw == "":
                return None
            if raw.isdigit():
                val = int(raw)
                if any(i == val for i, _ in items):
                    return val
            print("    invalid — try again")

    ins, outs = list_audio_devices()
    audio_in  = pick("AUDIO INPUT",  [(i, n) for i, n, _ in ins])
    audio_out = pick("AUDIO OUTPUT", [(i, n) for i, n, _ in outs])
    if audio_in is not None or audio_out is not None:
        try:
            audio_engine.set_devices(input_device=audio_in, output_device=audio_out)
            log.info(f"audio devices set — in={audio_in} out={audio_out}")
        except Exception as e:
            print(f"    audio setup error: {e}")
            _log_exception(f"device_setup audio in={audio_in} out={audio_out}")

    midi_out = pick("MIDI OUTPUT", list_midi_outputs())
    if midi_out is not None:
        try:
            name = midi_manager.open_index(midi_out)
            params.set("midi_enabled", True)
            params.set("midi_output_index", midi_out)
            print(f"    opened: {name}")
        except Exception as e:
            print(f"    error: {e}")

    midi_in = pick("MIDI INPUT", list_midi_inputs())
    if midi_in is not None:
        try:
            name = midi_manager.open_input_index(midi_in)
            params.set("midi_note_in_enabled", True)
            params.set("midi_note_in_port_index", midi_in)
            print(f"    opened: {name}")
        except Exception as e:
            print(f"    error: {e}")

    print("\n" + "=" * 86)
    print("  POTO — GRANULAR SAMPLING")
    print("  \u2500" * 33)
    print("  o  rec on/off    p  performance on/off    l  clear cloud    m  status")
    print("  workflow : o (record grains)  \u2192  o (stop)  \u2192  p (perform)")
    print("=" * 86)
    print("  /help  |  /menu  |  /status  |  /lib-status  |  r = random  |  0 = clear corpus  |  /quit")
    print("  /save [nom]  |  /load [nom]  |  /saves  |  /vis-on  |  /vis-off")
    print("=" * 86)
    print()

