def format_param_range(key):
    meta = PARAM_META.get(key, {})
    if "allowed" in meta:
        return f"allowed={meta['allowed']}"
    if "min" in meta and "max" in meta:
        return f"min={meta['min']} max={meta['max']}"
    return "free"

def cast_menu_value(key, typ, raw):
    if typ == "bool":
        lowered = raw.strip().lower()
        if lowered in {"1", "true", "on", "yes", "y"}:
            return True
        if lowered in {"0", "false", "off", "no", "n"}:
            return False
        raise ValueError("bool attendu: 0/1 true/false on/off")
    if typ == "int":
        return int(raw)
    if typ == "float":
        return float(raw)
    return str(raw).strip()

def clamp_value(key, value):
    meta = PARAM_META.get(key, {})
    if isinstance(value, bool):
        return value
    if meta.get("type") == "int":
        value = int(value)
    if meta.get("type") == "float":
        value = float(value)
    if "min" in meta and value < meta["min"]:
        raise ValueError(f"below min ({meta['min']})")
    if "max" in meta and value > meta["max"]:
        raise ValueError(f"above max ({meta['max']})")
    return value


