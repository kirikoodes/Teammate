# ── Logging setup ──────────────────────────────────────────────────────────────
_log_path = os.path.join(os.path.dirname(os.path.abspath(sys.argv[0])), "TEAMMATE.log")
logging.basicConfig(
    filename=_log_path,
    filemode="a",
    encoding="utf-8",
    level=logging.DEBUG,
    format="%(asctime)s [%(levelname)s] %(message)s",
    datefmt="%Y-%m-%d %H:%M:%S",
)
log = logging.getLogger("TEAMMATE")

def _log_exception(context=""):
    msg = f"{context}\n{traceback.format_exc()}" if context else traceback.format_exc()
    log.error(msg)

sys.excepthook = lambda t, v, tb: (
    log.critical("UNCAUGHT EXCEPTION\n" + "".join(traceback.format_exception(t, v, tb))),
    sys.__excepthook__(t, v, tb),
)
# ───────────────────────────────────────────────────────────────────────────────

